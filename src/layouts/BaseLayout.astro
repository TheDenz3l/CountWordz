---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Free SEO-driven text utility website for word counting, character counting, and text analysis tools.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content="Astro" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
    
    <title>{title} — CountWordz</title>
  </head>
  <body class="bg-brand-cream text-text-primary font-body min-h-[100dvh]">
    <slot />
  </body>
</html>
