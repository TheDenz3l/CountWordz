---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const page = {
  title: 'Terms of Service',
  description: 'Read the terms for using Word Counters and its text analysis tools, including advertising and third-party services.',
  h1: 'Terms of Service',
  updated: 'Last updated: April 2, 2026',
  intro: 'These terms describe the conditions for using Word Counters. By using the site, you agree to use the tools lawfully and responsibly and to comply with these terms.',
  sections: [
    {
      heading: 'Use of the tools',
      body: 'Word Counters is provided for general writing, counting, formatting, and readability assistance. You are responsible for how you use the output and for reviewing any text before publishing or submitting it.',
    },
    {
      heading: 'No guarantee of uninterrupted service',
      body: 'We aim to keep the site available and accurate, but we do not guarantee uninterrupted access, permanent availability, or suitability for any specific legal, academic, or professional requirement.',
    },
    {
      heading: 'Advertising',
      body: 'Word Counters displays third-party advertisements, including ads served by Google AdSense. These ads help support the free tools on this site. By using the site, you acknowledge that advertisements will be displayed alongside the content. You agree not to click on advertisements artificially or use any means to inflate ad impressions or clicks. Violation of this may result in termination of access to the site.',
    },
    {
      heading: 'Third-party services',
      body: 'Some pages include analytics, advertising, fonts, or other third-party resources. Those third parties may apply their own terms and policies. We are not responsible for the content or practices of third-party services. Your use of third-party services is at your own risk and subject to the terms and conditions of those third parties.',
    },
    {
      heading: 'Intellectual property',
      body: 'The content, design, and tools on Word Counters are the property of the site operator. You may not reproduce, distribute, or create derivative works from the site content without permission. Text you input into the tools remains your own property and is never stored by us.',
    },
    {
      heading: 'Acceptable use',
      body: 'You agree not to misuse the site, interfere with its operation, attempt unauthorized access, or use the service in a way that violates applicable law or the rights of others. You may not use automated tools to scrape, crawl, or otherwise extract content from the site beyond normal usage.',
    },
    {
      heading: 'Limitation of liability',
      body: 'Word Counters is provided "as is" without warranties of any kind, either express or implied. We are not liable for any damages arising from your use of the site, including but not limited to direct, indirect, incidental, or consequential damages.',
    },
    {
      heading: 'Updates',
      body: 'These terms may change as the product evolves. Continued use of the site after changes are published means you accept the updated version. We encourage you to review these terms periodically.',
    },
  ],
};
---

<BaseLayout title={`${page.title} — Word Counters`} description={page.description}>
  <main class="layout-shell px-4 py-10">
    <div class="max-w-4xl mx-auto">
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-3">{page.h1}</h1>
        <p class="text-sm text-text-muted">{page.updated}</p>
      </header>

      <article class="bg-surface rounded-2xl border border-gray-100 p-6 md:p-8 space-y-8">
        <p class="text-text-primary leading-7">{page.intro}</p>

        {page.sections.map((section) => (
          <section>
            <h2 class="text-2xl font-display font-bold mb-3">{section.heading}</h2>
            <p class="text-text-primary leading-7">{section.body}</p>
          </section>
        ))}
      </article>
    </div>
  </main>

  <Footer locale="en" />
</BaseLayout>
