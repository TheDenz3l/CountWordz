---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Meta Title Character Counter - Count Characters for SEO Page Titles" description="Free meta title character counter. Count characters for SEO page titles. Optimize for Google search results (60 chars recommended).">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Meta Title Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for SEO meta titles. Stay within Google's display limits for optimal search visibility.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Meta Title Character Limits</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Google Desktop</span><span class="font-semibold">~60 characters</span></li><li class="flex justify-between"><span>Google Mobile</span><span class="font-semibold">~50-60 characters</span></li><li class="flex justify-between"><span>Pixel Width</span><span class="font-semibold">600 pixels max</span></li><li class="flex justify-between"><span>Recommended</span><span class="font-semibold">50-60 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Meta Title Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Put primary keyword in first 50 characters</li><li>Include brand name at the end</li><li>Use separators: | or -</li><li>Write for humans, optimize for search</li><li>Avoid keyword stuffing</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/meta-description-counter" class="text-brand-pink hover:underline">Meta Description Counter</a></li><li><a href="/email-subject-counter" class="text-brand-pink hover:underline">Email Subject Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
