---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Discord Message Character Counter - Count Characters for Discord Messages" description="Free Discord character counter. Count characters for Discord messages (2,000 chars), nicknames (32 chars), and embed descriptions (4,096 chars).">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Discord Message Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for Discord messages, nicknames, and embeds. Stay within Discord's character limits.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Discord Character Limits 2026</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Message</span><span class="font-semibold">2,000 characters</span></li><li class="flex justify-between"><span>Nickname</span><span class="font-semibold">32 characters</span></li><li class="flex justify-between"><span>Embed Description</span><span class="font-semibold">4,096 characters</span></li><li class="flex justify-between"><span>Embed Title</span><span class="font-semibold">256 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Discord Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Use code blocks for long text (```text```)</li><li>Keep nicknames clear and recognizable</li><li>Use embed descriptions for announcements</li><li>Break long messages into multiple parts</li><li>Use Markdown for formatting</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/telegram-message-counter" class="text-brand-pink hover:underline">Telegram Message Counter</a></li><li><a href="/reddit-post-counter" class="text-brand-pink hover:underline">Reddit Post Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
