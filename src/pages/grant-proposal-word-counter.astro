---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Grant Proposal Word Counter - Count Words for Grant Applications" description="Free grant proposal word counter. Count words for grant applications and proposals. Track progress toward grant word limits.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Grant Proposal Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for grant proposals and applications. Stay within strict grant word limits to avoid disqualification.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Common Grant Word Limits</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>NSF Proposal</span><span class="font-semibold">15 pages (~5,000 words)</span></li><li class="flex justify-between"><span>NIH Grant</span><span class="font-semibold">6-12 pages per section</span></li><li class="flex justify-between"><span>Foundation Grants</span><span class="font-semibold">500-2,000 words</span></li><li class="flex justify-between"><span>Executive Summary</span><span class="font-semibold">250-500 words</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Grant Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Read word limits carefully — they're strict</li><li>Write concisely — every word counts</li><li>Use active voice to save space</li><li>Follow formatting guidelines exactly</li><li>Have someone else review for clarity</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/thesis-word-counter" class="text-brand-pink hover:underline">Thesis Word Counter</a></li><li><a href="/whitepaper-word-counter" class="text-brand-pink hover:underline">Whitepaper Word Counter</a></li><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
