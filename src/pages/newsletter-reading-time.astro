---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingTimeTool from '../components/ReadingTimeTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Newsletter Reading Time Calculator - Estimate Reading Time for Newsletters" description="Free newsletter reading time calculator. Estimate how long it takes to read newsletters. Optimize newsletter length for subscriber engagement.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Newsletter Reading Time Calculator</h1><p class="text-base text-text-muted max-w-3xl">Estimate reading time for newsletters. Optimize your newsletter length for maximum subscriber engagement and click-through rates.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadingTimeTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Newsletter Reading Time Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Daily Newsletter</span><span class="font-semibold">2-5 minutes</span></li><li class="flex justify-between"><span>Weekly Newsletter</span><span class="font-semibold">5-10 minutes</span></li><li class="flex justify-between"><span>Monthly Newsletter</span><span class="font-semibold">10-15 minutes</span></li><li class="flex justify-between"><span>Optimal Length</span><span class="font-semibold">3-7 minutes</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Newsletter Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Lead with most important content</li><li>Use scannable formatting</li><li>Include clear sections</li><li>Link to full articles</li><li>Respect subscribers' time</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/email-reading-time" class="text-brand-pink hover:underline">Email Reading Time</a></li><li><a href="/blog-reading-time" class="text-brand-pink hover:underline">Blog Reading Time</a></li><li><a href="/reading-time-calculator" class="text-brand-pink hover:underline">Reading Time Calculator</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="reading-time" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
