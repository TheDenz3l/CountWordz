---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="WhatsApp Message Character Counter - Count Characters for WhatsApp Messages" description="Free WhatsApp character counter. Count characters for WhatsApp messages (4,096 chars), status updates (139 chars), and about section (139 chars).">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">WhatsApp Message Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for WhatsApp messages, status updates, and profile sections. Optimize your WhatsApp communication.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">WhatsApp Character Limits 2026</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Message</span><span class="font-semibold">4,096 characters</span></li><li class="flex justify-between"><span>Status Update</span><span class="font-semibold">139 characters</span></li><li class="flex justify-between"><span>About Section</span><span class="font-semibold">139 characters</span></li><li class="flex justify-between"><span>Broadcast List Name</span><span class="font-semibold">24 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">WhatsApp Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Keep status updates concise (under 139 chars)</li><li>Use emojis to convey emotion efficiently</li><li>Break long messages into paragraphs</li><li>Use bold (*text*) and italic (_text_) for emphasis</li><li>Keep business messages clear and actionable</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/sms-character-counter" class="text-brand-pink hover:underline">SMS Character Counter</a></li><li><a href="/telegram-message-counter" class="text-brand-pink hover:underline">Telegram Message Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
