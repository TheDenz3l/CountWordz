---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
---
<BaseLayout title="Paragraph Word Counter - Count Words per Paragraph" description="Free paragraph word counter tool. Count words per paragraph and analyze paragraph structure for better writing.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Paragraph Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words per paragraph and analyze paragraph structure. Improve your writing balance and flow.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">How to Use the Paragraph Word Counter</h2><p class="text-text-primary mb-4">Paste your text above to see total word count and paragraph breakdown. Analyze paragraph length for better readability and balance.</p></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Ideal Paragraph Length</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Academic writing</span><span class="font-semibold">100-200 words per paragraph</span></li><li class="flex justify-between"><span>Blog posts</span><span class="font-semibold">50-150 words per paragraph</span></li><li class="flex justify-between"><span>Web content</span><span class="font-semibold">30-100 words per paragraph</span></li><li class="flex justify-between"><span>Journalism</span><span class="font-semibold">20-80 words per paragraph</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Why Paragraph Length Matters</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Short paragraphs improve readability on screens</li><li>Long paragraphs can overwhelm readers</li><li>Varying paragraph length creates visual interest</li><li>Each paragraph should focus on one main idea</li><li>White space between paragraphs gives readers a break</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Paragraph Structure Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Start with a clear topic sentence</li><li>Support with evidence, examples, or explanation</li><li>End with a transition or concluding thought</li><li>Keep paragraphs focused—one main idea each</li><li>Break up long paragraphs for better readability</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">FAQs</h2><h3 class="text-xl font-display font-semibold mt-4 mb-2">How long is too long for a paragraph?</h3><p class="text-text-primary mb-4">For web content, paragraphs over 150 words can feel dense. For academic writing, 200+ words is acceptable if the content warrants it. When in doubt, break it up.</p><h3 class="text-xl font-display font-semibold mt-4 mb-2">Can a paragraph be one sentence?</h3><p class="text-text-primary mb-4">Yes, single-sentence paragraphs are effective for emphasis, transitions, or dramatic effect. Use them sparingly for maximum impact.</p></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li><li><a href="/sentence-counter" class="text-brand-pink hover:underline">Sentence Counter</a></li><li><a href="/readability-checker" class="text-brand-pink hover:underline">Readability Checker</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <!-- Footer Ad Banner -->
  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
