---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SyllableCounterTool from '../../../components/SyllableCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Silbenzähler - Zählt Silben in Wörtern" 
  description="Kostenloser Silbenzähler. Zählen Sie Gesamtsilben und durchschnittliche Silben pro Wort. Als geschätzt gekennzeichnet."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Silbenzähler</h1>
      <p class="text-base text-text-muted max-w-3xl">Zählen Sie Silben in Wörtern und Text. Perfekt für Lesbarkeitsanalyse und Poesie.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <SyllableCounterTool locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Wie Es Funktioniert</h2>
            <p class="text-text-primary mb-4">Wir verwenden linguistische Algorithmen zur Schätzung der Silbenzählung. Englische Regeln können variieren.</p>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ähnliche Tools</h2>
            <ul class="space-y-2">
              <li><a href="/de/word-counter" class="text-brand-pink hover:underline">Wortzähler</a></li>
              <li><a href="/de/readability-checker" class="text-brand-pink hover:underline">Lesbarkeitsprüfer</a></li>
              <li><a href="/de/reading-time-calculator" class="text-brand-pink hover:underline">Lesezeit</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="syllable-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
