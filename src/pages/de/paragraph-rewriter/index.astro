---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ParagraphRewriter from '../../../components/ParagraphRewriter';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Überarbeiter - Verbessert die Klarheit Ihres Schreibens" 
  description="Kostenloser Absatz-Überarbeiter. Erhalten Sie Vorschläge zur Verbesserung der Klarheit, Lesbarkeit und Struktur Ihres Schreibens."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Überarbeiter</h1>
      <p class="text-base text-text-muted max-w-3xl">Erhalten Sie intelligente Vorschläge zur Verbesserung Ihres Schreibens. Korrigieren Sie Passiv, kürzen Sie lange Sätze, vereinfachen Sie komplexe Wörter.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <ParagraphRewriter locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Was Dieses Tool Verbessert</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li><strong>Passiv</strong> — Schlägt Umwandlung in Aktiv vor</li>
                <li><strong>Lange Sätze</strong> — Empfiehlt Teilung von Sätzen über 25 Wörtern</li>
                <li><strong>Komplexe Wörter</strong> — Schlägt einfachere Alternativen vor</li>
                <li><strong>Wiederholung</strong> — Identifiziert übermäßig verwendete Wörter</li>
                <li><strong>Lesbarkeit</strong> — Zeigt verbesserte Lesbarkeitswerte</li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ähnliche Tools</h2>
            <ul class="space-y-2">
              <li><a href="/de/word-counter" class="text-brand-pink hover:underline">Wortzähler</a></li>
              <li><a href="/de/text-compare-tool" class="text-brand-pink hover:underline">Textvergleich</a></li>
              <li><a href="/de/readability-checker" class="text-brand-pink hover:underline">Lesbarkeitsprüfer</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="paragraph-rewriter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
