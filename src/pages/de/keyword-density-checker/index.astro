---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import KeywordDensityChecker from '../../../components/KeywordDensityChecker';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
---

<BaseLayout 
  title="Keyword-Dichte - Analysiert Worthäufigkeit" 
  description="Kostenloser Keyword-Dichte-Prüfer. Analysieren Sie Worthäufigkeit für SEO-Optimierung."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Keyword-Dichte</h1>
      <p class="text-base text-text-muted max-w-3xl">Analysieren Sie die Worthäufigkeit in Ihrem Text. Optimieren Sie Ihren Inhalt für SEO.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <KeywordDensityChecker locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Optimale Keyword-Dichte</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>Optimal</span><span class="font-semibold">1-2%</span></li>
                <li class="flex justify-between"><span>Akzeptabel</span><span class="font-semibold">2-3%</span></li>
                <li class="flex justify-between"><span>Zu hoch</span><span class="font-semibold">3%+</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ähnliche Tools</h2>
            <ul class="space-y-2">
              <li><a href="/de/word-counter" class="text-brand-pink hover:underline">Wortzähler</a></li>
              <li><a href="/de/readability-checker" class="text-brand-pink hover:underline">Lesbarkeitsprüfer</a></li>
              <li><a href={getLocalizedToolPath('de', 'seo-content-readability-checker')} class="text-brand-pink hover:underline">SEO-Lesbarkeit</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="keyword-density" />
    </div>
  </main>

  <Footer />
</BaseLayout>
