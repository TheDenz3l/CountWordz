---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WordCounterTool from '../../../components/WordCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import Icon from '../../../components/Icon.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Wie werden Wörter gezählt?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Wir zählen Wörter, indem wir den Text an Leerzeichen aufteilen und leere Einträge herausfiltern. Wörter mit Bindestrich zählen wie ein einzelnes Wort.',
      },
    },
    {
      '@type': 'Question',
      name: 'Ist die Lesezeit genau?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die Lesezeit basiert auf einer durchschnittlichen Lesegeschwindigkeit von etwa 200 Wörtern pro Minute. Die tatsächliche Zeit hängt vom Schwierigkeitsgrad des Textes ab.',
      },
    },
    {
      '@type': 'Question',
      name: 'Sind Leerzeichen in der Zeichenzahl enthalten?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja. Wir zeigen sowohl die Zeichenzahl mit Leerzeichen als auch ohne Leerzeichen an, damit Sie die passende Kennzahl für Ihren Zweck nutzen können.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kann ich das für akademische Texte nutzen?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja. Das Tool eignet sich für Aufsätze, Hausarbeiten und Berichte, da es Wörter, Sätze, Absätze und die geschätzte Lesezeit zuverlässig anzeigt.',
      },
    },
    {
      '@type': 'Question',
      name: 'Brauche ich ein Konto?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nein. Das Tool ist kostenlos und ohne Anmeldung nutzbar. Text einfügen und sofort mit dem Zählen beginnen.',
      },
    },
  ],
};
---

<BaseLayout 
  title="Wortzähler - Wörter, Zeichen und Mehr Zählen" 
  description="Kostenloser Wortzähler. Zählen Sie Wörter, Zeichen, Sätze, Absätze und schätzen Sie Lesezeit in Echtzeit."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Wortzähler</h1>
      <p class="text-base text-text-muted max-w-3xl">Zählen Sie Wörter, Zeichen, Sätze und mehr in Echtzeit. Perfekt für Aufsätze, Lebensläufe, Beiträge und Skripte.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <WordCounterTool locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">So Verwenden Sie den Wortzähler</h2>
            <p class="text-text-primary mb-4">Fügen Sie Ihren Text oben ein oder schreiben Sie direkt hinein. Das Tool zeigt sofort:</p>
            <ul class="list-disc list-inside space-y-2 text-text-primary">
              <li><strong>Wortanzahl</strong> — Gesamtzahl aller Wörter</li>
              <li><strong>Zeichenanzahl</strong> — Mit und ohne Leerzeichen</li>
              <li><strong>Satzanzahl</strong> — Anzahl der Sätze</li>
              <li><strong>Absatzanzahl</strong> — Anzahl der Absätze</li>
              <li><strong>Lesezeit</strong> — Geschätzte Lesezeit</li>
              <li><strong>Sprechzeit</strong> — Geschätzte Sprechzeit</li>
            </ul>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal für</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h3 class="font-semibold text-brand-pink mb-2">Schüler und Lehrkräfte</h3>
                <p class="text-text-muted text-sm">Prüfen Sie Aufsatzlängen, kontrollieren Sie Aufgabenanforderungen und erhalten Sie einen schnellen Überblick über Umfang und Struktur eines Textes.</p>
              </div>
              <div>
                <h3 class="font-semibold text-brand-cyan mb-2">Content-Teams</h3>
                <p class="text-text-muted text-sm">Bewerten Sie Blogbeiträge, Newsletter und Landingpage-Texte, damit Inhalte die richtige Länge und Lesedauer erreichen.</p>
              </div>
              <div>
                <h3 class="font-semibold text-brand-orange mb-2">Bewerber</h3>
                <p class="text-text-muted text-sm">Behalten Sie Lebensläufe, Anschreiben und Kurzprofile unter Kontrolle, wenn jedes Wort präzise und relevant sein muss.</p>
              </div>
              <div>
                <h3 class="font-semibold text-brand-pink mb-2">SEO-Redakteure</h3>
                <p class="text-text-muted text-sm">Vergleichen Sie Textlängen, planen Sie Lesedauer und erstellen Sie Inhalte, die zu Suchintention und Nutzererwartung passen.</p>
              </div>
            </div>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Praktische Tipps</h2>
            <ul class="space-y-4">
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Vor dem Einreichen prüfen:</strong> Kontrollieren Sie Wortanzahl und Absatzstruktur, bevor Sie einen Text abgeben oder veröffentlichen.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Lesezeit mitdenken:</strong> Nutzen Sie die geschätzte Lesezeit, um Blogbeiträge und Artikel besser an die Zielgruppe anzupassen.</span></li>
              <li class="flex gap-3"><span class="text-brand-orange font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Satzlänge beobachten:</strong> Kürzere, klarere Sätze verbessern die Lesbarkeit. Der Satzzähler hilft beim Erkennen zu langer Passagen.</span></li>
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Unterschiedliche Formate vergleichen:</strong> Aufsätze, Lebensläufe und Social-Media-Texte haben andere Anforderungen. Passen Sie die Länge an das Format an.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Mehr als nur Wörter beachten:</strong> Zeichen, Sätze und Absätze geben zusätzliche Hinweise auf Struktur und Verständlichkeit.</span></li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Häufig gestellte Fragen</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Wie werden Wörter gezählt?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Wir teilen den Text an Leerzeichen und filtern leere Einträge heraus. Bindestrich-Wörter werden wie ein einzelnes Wort behandelt.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Ist die Lesezeit genau?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Sie ist eine solide Schätzung auf Basis einer durchschnittlichen Lesegeschwindigkeit. Schwierige oder sehr technische Texte benötigen oft etwas länger.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Sind Leerzeichen in der Zeichenzahl enthalten?<span class="text-brand-orange group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Ja. Zusätzlich zeigen wir auch die Zeichenzahl ohne Leerzeichen, damit Sie beide Werte vergleichen können.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Ist das für akademische Texte geeignet?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Ja. Das Tool ist besonders nützlich für Aufsätze, Berichte und wissenschaftliche Texte, wenn Wortgrenzen eingehalten werden müssen.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Brauche ich ein Konto?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Nein. Sie können das Tool sofort kostenlos und ohne Anmeldung nutzen.</p></details>
          </section>


          <div class="my-6 ad-slot-bottom">
            <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
              <p class="text-xs text-text-muted mb-2">Werbung</p>
              <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
                <span class="text-gray-400 text-sm">Werbeplatz</span>
              </div>
            </div>
          </div>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Ähnliche Tools</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href="/de/character-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="text" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Zeichenzähler</h3><p class="text-xs text-text-muted">Zeichen präzise messen</p></a>
              <a href="/de/sentence-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="note" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Satzzähler</h3><p class="text-xs text-text-muted">Satzstruktur prüfen</p></a>
              <a href="/de/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="book" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Lesbarkeitsprüfer</h3><p class="text-xs text-text-muted">Verständlichkeit messen</p></a>
              <a href="/de/case-converter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="text" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Groß-/Kleinschreibung</h3><p class="text-xs text-text-muted">Textformat schnell ändern</p></a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="word-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
