---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingTimeTool from '../../../components/ReadingTimeTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
---

<BaseLayout 
  title="Lesezeit-Rechner - Schätzt die Lesezeit" 
  description="Kostenloser Lesezeit-Rechner. Schätzen Sie, wie lange es dauert, Ihren Text zu lesen. Optimieren Sie die Länge Ihres Inhalts."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Lesezeit-Rechner</h1>
      <p class="text-base text-text-muted max-w-3xl">Schätzen Sie die Lese- und Sprechzeit für Ihren Text. Optimieren Sie die Länge Ihres Inhalts.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <ReadingTimeTool locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Lesegeschwindigkeiten</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>Langsamer Leser</span><span class="font-semibold">150-200 WPM</span></li>
                <li class="flex justify-between"><span>Durchschnitt</span><span class="font-semibold">200-250 WPM</span></li>
                <li class="flex justify-between"><span>Schneller Leser</span><span class="font-semibold">250-300 WPM</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ähnliche Tools</h2>
            <ul class="space-y-2">
              <li><a href="/de/word-counter" class="text-brand-pink hover:underline">Wortzähler</a></li>
              <li><a href={getLocalizedToolPath('de', 'speech-time-calculator')} class="text-brand-pink hover:underline">Sprechzeit</a></li>
              <li><a href={getLocalizedToolPath('de', 'blog-reading-time')} class="text-brand-pink hover:underline">Blog-Lesezeit</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="reading-time" />
    </div>
  </main>

  <Footer />
</BaseLayout>
