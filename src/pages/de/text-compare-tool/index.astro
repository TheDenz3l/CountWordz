---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TextDiffTool from '../../../components/TextDiffTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import Icon from '../../../components/Icon.astro';
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Wie vergleicht das Tool Texte?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es vergleicht Wort für Wort in Reihenfolge und markiert Unterschiede.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kann es Ergänzungen und Löschungen erkennen?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja, beide Änderungsarten werden hervorgehoben.',
      },
    },
    {
      '@type': 'Question',
      name: 'Ist das für Verträge oder Dokumente geeignet?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja, es eignet sich gut zum Vergleich überarbeiteter Versionen.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wird auch Ähnlichkeit angezeigt?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja, eine Quote zeigt schnell, wie stark sich die Versionen unterscheiden.',
      },
    },
    {
      '@type': 'Question',
      name: 'Brauche ich ein Konto?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nein.',
      },
    },
  ],
};

---

<BaseLayout 
  title="Textvergleich - Vergleicht Zwei Texte" 
  description="Vergleichen Sie zwei Texte nebeneinander und markieren Sie Unterschiede präzise."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Textvergleich</h1>
      <p class="text-base text-text-muted max-w-3xl">Vergleichen Sie zwei Texte nebeneinander und markieren Sie Unterschiede präzise.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <TextDiffTool locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Textvergleich</h2>
            <p class="text-text-primary mb-4">Fügen Sie Original- und überarbeitete Version ein, um Ergänzungen, Löschungen und Änderungen übersichtlich zu erkennen.</p>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal für</h2>
            <p class="text-text-primary">Dokumentenprüfung, Änderungsverfolgung, Content-Editing und Vergleich zwischen Versionen.</p>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Praktische Tipps</h2>
            <ul class="space-y-4">
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Vergleichen Sie Versionen ähnlicher Länge.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Bei langen Texten ist ein Abschnittsvergleich oft klarer.</span></li>
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Nutzen Sie die Ähnlichkeitsquote als schnellen Überblick.</span></li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Häufig gestellte Fragen</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Wie vergleicht das Tool Texte?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Es vergleicht Wort für Wort in Reihenfolge und markiert Unterschiede.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Kann es Ergänzungen und Löschungen erkennen?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Ja, beide Änderungsarten werden hervorgehoben.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Ist das für Verträge oder Dokumente geeignet?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Ja, es eignet sich gut zum Vergleich überarbeiteter Versionen.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Wird auch Ähnlichkeit angezeigt?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Ja, eine Quote zeigt schnell, wie stark sich die Versionen unterscheiden.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Brauche ich ein Konto?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Nein.</p>
            </details>
          </section>


          <div class="my-6 ad-slot-bottom">
            <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
              <p class="text-xs text-text-muted mb-2">Werbung</p>
              <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
                <span class="text-gray-400 text-sm">Werbeplatz</span>
              </div>
            </div>
          </div>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Ähnliche Tools</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href="/de/word-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="chart" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Wortzähler</h3>
              </a>
              <a href="/de/paragraph-rewriter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="text" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Absatz-Umschreiber</h3>
              </a>
              <a href="/de/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="book" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Lesbarkeitsprüfer</h3>
              </a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="text-compare" />
    </div>
  </main>

  <Footer />
</BaseLayout>
