---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CharacterCounterTool from '../../../components/CharacterCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
---

<BaseLayout 
  title="Zeichenzähler - Überprüft Zeichenlimits für Soziale Medien" 
  description="Kostenloser Zeichenzähler. Zählen Sie Zeichen mit und ohne Leerzeichen. Überprüfen Sie Limits für X, Instagram, LinkedIn und mehr."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Zeichenzähler</h1>
      <p class="text-base text-text-muted max-w-3xl">Zählen Sie Zeichen mit und ohne Leerzeichen. Überprüfen Sie Limits für Beiträge in sozialen Medien.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CharacterCounterTool locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Limits pro Plattform</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>X (Twitter)</span><span class="font-semibold">280 Zeichen</span></li>
                <li class="flex justify-between"><span>Instagram Caption</span><span class="font-semibold">2,200 Zeichen</span></li>
                <li class="flex justify-between"><span>LinkedIn Post</span><span class="font-semibold">3,000 Zeichen</span></li>
                <li class="flex justify-between"><span>Meta Description</span><span class="font-semibold">160 Zeichen</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Wie Man Verwendet</h2>
            <p class="text-text-primary mb-4">Fügen Sie Ihren Text ein. Der Zähler zeigt:</p>
            <ul class="list-disc list-inside space-y-2 text-text-primary">
              <li><strong>Zeichen mit Leerzeichen</strong> — Alle Zeichen</li>
              <li><strong>Zeichen ohne Leerzeichen</strong> — Nur Buchstaben</li>
              <li><strong>Wortanzahl</strong> — Gesamtzahl der Wörter</li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ähnliche Tools</h2>
            <ul class="space-y-2">
              <li><a href={getLocalizedToolPath('de', 'tweet-character-counter', 'character-counter')} class="text-brand-pink hover:underline">Tweet-Zähler</a></li>
              <li><a href={getLocalizedToolPath('de', 'instagram-caption-counter', 'character-counter')} class="text-brand-pink hover:underline">Instagram Caption</a></li>
              <li><a href="/de/word-counter" class="text-brand-pink hover:underline">Wortzähler</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="character-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
