---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CaseConverterTool from '../../../components/CaseConverterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Groß-/Kleinschreibung-Konverter - Konvertiert Textformate" 
  description="Kostenloser Groß-/Kleinschreibung-Konverter. Konvertiert Text zwischen klein, GROSS, Titel, Satz und mehr."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Groß-/Kleinschreibung</h1>
      <p class="text-base text-text-muted max-w-3xl">Konvertieren Sie Text zwischen verschiedenen Groß- und Kleinschreibungsformaten. Perfekt für Titel.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CaseConverterTool locale="de" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Werbung</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Werbeplatz</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Verfügbare Formate</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li><strong>klein</strong> — Alles klein</li>
                <li><strong>GROSS</strong> — Alles groß</li>
                <li><strong>Titel</strong> — Erster Buchstabe jedes Wortes groß</li>
                <li><strong>Satz</strong> — Erster Buchstabe des Satzes groß</li>
                <li><strong>aLTERNIEREND</strong> — Wechselt zwischen groß und klein</li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ähnliche Tools</h2>
            <ul class="space-y-2">
              <li><a href="/de/word-counter" class="text-brand-pink hover:underline">Wortzähler</a></li>
              <li><a href="/de/title-case-converter" class="text-brand-pink hover:underline">Titel-Konverter</a></li>
              <li><a href="/de/character-counter" class="text-brand-pink hover:underline">Zeichenzähler</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="case-converter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
