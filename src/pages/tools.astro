---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="All Text Tools - Complete List of 103 Free Text Utilities" 
  description="Complete list of all 103 free text tools at CountWordz. Browse by category: word counters, character counters, readability checkers, reading time calculators, and more."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-8">
      <h1 class="text-4xl md:text-6xl font-display font-bold tracking-tighter text-text-primary mb-3">All Text Tools</h1>
      <p class="text-lg text-text-muted max-w-3xl">Browse all 103 free text tools organized by category. Find the perfect tool for your writing, editing, and content optimization needs.</p>
    </header>

    <!-- Core Tools -->
    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-pink">Core Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/word-counter" class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
          <h3 class="font-semibold text-brand-pink">Word Counter</h3>
          <p class="text-sm text-text-muted mt-1">Count words, characters, sentences, and more</p>
        </a>
        <a href="/character-counter" class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
          <h3 class="font-semibold text-brand-cyan">Character Counter</h3>
          <p class="text-sm text-text-muted mt-1">Check character limits for social media</p>
        </a>
        <a href="/sentence-counter" class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
          <h3 class="font-semibold text-brand-orange">Sentence Counter</h3>
          <p class="text-sm text-text-muted mt-1">Count sentences and analyze structure</p>
        </a>
        <a href="/paragraph-counter" class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
          <h3 class="font-semibold text-brand-pink">Paragraph Counter</h3>
          <p class="text-sm text-text-muted mt-1">Count paragraphs and average words</p>
        </a>
        <a href="/syllable-counter" class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
          <h3 class="font-semibold text-brand-cyan">Syllable Counter</h3>
