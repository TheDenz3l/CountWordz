---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WordCounterTool from '../../components/WordCounterTool';
import Footer from '../../components/Footer.astro';
import { getLocalizedStaticPath, getLocalizedToolPath } from '../../lib/locale-routes';

const locale = 'pt';

const stats = [
  { value: '103', label: 'Ferramentas gratuitas', accent: 'text-brand-pink' },
  { value: '100%', label: 'Grátis', accent: 'text-brand-cyan' },
  { value: 'Tempo real', label: 'Resultados', accent: 'text-brand-orange' },
  { value: 'Sem cadastro', label: 'Necessário', accent: 'text-text-primary' },
];

const topTools = [
  { slug: 'word-counter', title: 'Contador de palavras', description: 'Conte palavras, caracteres, frases e estime o tempo de leitura.', accent: 'text-brand-pink' },
  { slug: 'character-counter', title: 'Contador de caracteres', description: 'Verifique limites para X, Instagram, LinkedIn e textos meta.', accent: 'text-brand-cyan' },
  { slug: 'sentence-counter', title: 'Contador de frases', description: 'Conte frases e analise a estrutura do texto.', accent: 'text-brand-orange' },
  { slug: 'paragraph-counter', title: 'Contador de parágrafos', description: 'Conte parágrafos e a média de palavras por parágrafo.', accent: 'text-brand-pink' },
  { slug: 'syllable-counter', title: 'Contador de sílabas', description: 'Conte sílabas em palavras isoladas ou no texto inteiro.', accent: 'text-brand-cyan' },
  { slug: 'reading-time-calculator', title: 'Calculadora de tempo de leitura', description: 'Estime o tempo de leitura e de fala do seu conteúdo.', accent: 'text-brand-orange' },
  { slug: 'case-converter', title: 'Conversor de caixa', description: 'Converta texto em minúsculas, MAIÚSCULAS, título ou frase.', accent: 'text-brand-pink' },
  { slug: 'title-case-converter', title: 'Conversor para título', description: 'Ajuste títulos ao formato correto segundo guias de estilo.', accent: 'text-brand-cyan' },
  { slug: 'readability-checker', title: 'Verificador de legibilidade', description: 'Meça a legibilidade com pontuações Flesch e nível escolar.', accent: 'text-brand-orange' },
  { slug: 'keyword-density-checker', title: 'Densidade de palavras-chave', description: 'Analise a frequência de palavras e expressões para SEO.', accent: 'text-brand-pink' },
  { slug: 'text-compare-tool', title: 'Comparador de texto', description: 'Compare duas versões e identifique diferenças rapidamente.', accent: 'text-brand-cyan' },
  { slug: 'paragraph-rewriter', title: 'Reescritor de parágrafos', description: 'Receba sugestões para deixar a escrita mais clara e melhor.', accent: 'text-brand-orange' },
];

const popularUseCases = [
  { slug: 'essay-word-counter', category: 'word-counter', title: 'Contador de ensaios', description: 'Para estudantes e redatores', accent: 'text-brand-pink' },
  { slug: 'resume-word-counter', category: 'word-counter', title: 'Contador de currículos', description: 'Para candidaturas', accent: 'text-brand-cyan' },
  { slug: 'tweet-character-counter', category: 'character-counter', title: 'Contador de tweets', description: 'Para X / Twitter', accent: 'text-brand-orange' },
  { slug: 'instagram-caption-counter', category: 'character-counter', title: 'Legenda do Instagram', description: 'Para publicações sociais', accent: 'text-brand-pink' },
];
---

<BaseLayout
  title="CountWordz - Ferramentas de texto gratuitas"
  description="Ferramentas de texto gratuitas: contador de palavras, contador de caracteres, verificador de legibilidade e mais. Rápido, moderno e fácil de usar."
>
  <section class="bg-gradient-to-br from-brand-cream to-white py-16 md:py-24">
    <div class="layout-shell px-4">
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-7xl font-display font-bold tracking-tighter text-text-primary mb-4">CountWordz</h1>
        <p class="text-xl text-text-muted max-w-2xl mx-auto">Ferramentas de texto gratuitas para contar, analisar e formatar texto. Rápido, moderno e fácil de usar.</p>
      </div>

      <div class="max-w-4xl mx-auto bg-surface rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <WordCounterTool locale={locale} client:load />
      </div>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="layout-shell px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((item) => (
          <div class="p-6">
            <div class={`text-3xl font-display font-bold ${item.accent}`}>{item.value}</div>
            <div class="text-sm text-text-muted mt-1">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 bg-gray-50">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center max-w-4xl mx-auto">
        <p class="text-xs text-text-muted mb-2">Publicidade</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">Espaço publicitário (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="layout-shell px-4">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-center mb-4">Ferramentas principais</h2>
      <p class="text-center text-text-muted mb-12 max-w-2xl mx-auto">
        Comece com nossas ferramentas essenciais de análise de texto, ou
        <a href={getLocalizedStaticPath(locale, 'tools')} class="text-brand-pink hover:underline font-semibold"> veja as 103 ferramentas →</a>
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {topTools.map((tool) => (
          <a href={getLocalizedStaticPath(locale, tool.slug)} class="bg-surface p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block">
            <h3 class={`text-xl font-display font-semibold mb-2 ${tool.accent}`}>{tool.title}</h3>
            <p class="text-text-muted">{tool.description}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href={getLocalizedStaticPath(locale, 'tools')} class="inline-block px-8 py-3 bg-brand-pink text-white rounded-lg font-semibold hover:bg-opacity-90 transition-all">Ver as 103 ferramentas →</a>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center max-w-4xl mx-auto">
        <p class="text-xs text-text-muted mb-2">Publicidade</p>
        <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">Espaço publicitário (300x250)</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-gray-50 border-y border-gray-100">
    <div class="layout-shell px-4">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-center mb-8">Casos de uso populares</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {popularUseCases.map((item) => (
          <a href={getLocalizedToolPath(locale, item.slug, item.category)} class="text-center p-4 rounded-lg hover:bg-gray-50 transition-colors">
            <div class={`${item.accent} font-semibold mb-1`}>{item.title}</div>
            <div class="text-xs text-text-muted">{item.description}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center max-w-4xl mx-auto">
        <p class="text-xs text-text-muted mb-2">Publicidade</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">Espaço publicitário (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</BaseLayout>
