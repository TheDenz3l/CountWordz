---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SentenceCounterTool from '../../../components/SentenceCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Contador de Frases - Conta e Analisa Frases" 
  description="Contador de frases gratuito. Conte frases, média de palavras por frase e analise a estrutura do texto."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Contador de Frases</h1>
      <p class="text-base text-text-muted max-w-3xl">Conte frases e analise a estrutura das frases. Perfeito para melhorar a clareza da sua escrita.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <SentenceCounterTool locale="pt" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Como Funciona</h2>
            <p class="text-text-primary mb-4">Nosso contador detecta frases com base na pontuação, ignorando abreviações comuns.</p>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ferramentas Relacionadas</h2>
            <ul class="space-y-2">
              <li><a href="/pt/word-counter" class="text-brand-pink hover:underline">Contador de Palavras</a></li>
              <li><a href="/pt/paragraph-counter" class="text-brand-pink hover:underline">Contador de Parágrafos</a></li>
              <li><a href="/pt/readability-checker" class="text-brand-pink hover:underline">Verificador de Legibilidade</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="sentence-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
