---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CaseConverterTool from '../../../components/CaseConverterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import Icon from '../../../components/Icon.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Para que serve um conversor de caixa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ele permite transformar texto rapidamente em minúsculas, MAIÚSCULAS, título, frase e outros formatos úteis para edição e publicação.',
      },
    },
    {
      '@type': 'Question',
      name: 'Qual é a diferença entre título e frase?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'O formato título capitaliza palavras importantes de um cabeçalho. O formato frase mantém uma capitalização mais natural do texto corrido.',
      },
    },
    {
      '@type': 'Question',
      name: 'Posso corrigir um texto já escrito?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim. Basta colar o texto na ferramenta e escolher o formato desejado para aplicar a conversão na hora.',
      },
    },
    {
      '@type': 'Question',
      name: 'Isso é útil para títulos e redes sociais?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim. A ferramenta ajuda a padronizar títulos, chamadas e textos curtos para diferentes canais.',
      },
    },
    {
      '@type': 'Question',
      name: 'Preciso de cadastro?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Não. O conversor é gratuito e pode ser usado imediatamente, sem conta.',
      },
    },
  ],
};
---

<BaseLayout 
  title="Conversor de Caixa - Converte entre Formatos de Texto" 
  description="Conversor de caixa gratuito. Converte texto entre minúsculas, MAIÚSCULAS, Título, Frase e mais."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Conversor de Caixa</h1>
      <p class="text-base text-text-muted max-w-3xl">Converta texto entre diferentes formatos de maiúsculas e minúsculas. Ideal para títulos, CTAs, conteúdo web e textos que precisam de consistência visual.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CaseConverterTool locale="pt" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Formatos Disponíveis</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li><strong>minúsculas</strong> — tudo em letras minúsculas</li>
                <li><strong>MAIÚSCULAS</strong> — tudo em letras maiúsculas</li>
                <li><strong>Título</strong> — capitalização voltada para cabeçalhos</li>
                <li><strong>Frase</strong> — início de frase em maiúscula</li>
                <li><strong>aLtErNaDo</strong> — alternância entre maiúsculas e minúsculas</li>
              </ul>
            </div>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal Para</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div><h3 class="font-semibold text-brand-pink mb-2">Editores e Redatores</h3><p class="text-text-muted text-sm">Padronize títulos, subtítulos e blocos de texto antes da publicação.</p></div>
              <div><h3 class="font-semibold text-brand-cyan mb-2">Times de Marketing</h3><p class="text-text-muted text-sm">Ajuste CTAs, anúncios e textos curtos para manter consistência entre campanhas e canais.</p></div>
              <div><h3 class="font-semibold text-brand-orange mb-2">Estudantes</h3><p class="text-text-muted text-sm">Corrija rapidamente títulos e formatos em trabalhos, slides e documentos acadêmicos.</p></div>
              <div><h3 class="font-semibold text-brand-pink mb-2">Uso Diário</h3><p class="text-text-muted text-sm">Ganhe tempo ao consertar textos mal formatados, copiados de PDFs ou escritos inteiramente em maiúsculas.</p></div>
            </div>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Dicas Práticas</h2>
            <ul class="space-y-4">
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Escolha o formato certo:</strong> título funciona bem para cabeçalhos, frase para texto editorial e maiúsculas com moderação.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Revise nomes próprios:</strong> alguns termos podem precisar de conferência manual após a conversão.</span></li>
              <li class="flex gap-3"><span class="text-brand-orange font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Padronize CTAs:</strong> manter o mesmo estilo melhora consistência e percepção de marca.</span></li>
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Limpe textos copiados:</strong> a ferramenta é útil depois de colar conteúdo vindo de PDFs ou documentos externos.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Use junto com o contador de caracteres:</strong> assim você ajusta formato e tamanho no mesmo fluxo.</span></li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Perguntas Frequentes</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Para que serve um conversor de caixa?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Serve para mudar rapidamente o formato visual do texto e adaptá-lo a títulos, páginas, campanhas e tarefas do dia a dia.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Qual a diferença entre título e frase?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">O formato título destaca palavras importantes do cabeçalho. O formato frase respeita uma capitalização mais natural de texto corrido.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Posso corrigir um texto já pronto?<span class="text-brand-orange group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Sim. Cole o texto, escolha a transformação desejada e aplique a conversão na hora.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Isso ajuda em redes sociais?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Sim. É útil para padronizar títulos, chamadas e textos curtos antes de publicar.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Preciso de cadastro?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Não. O uso é gratuito e imediato.</p></details>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Ferramentas Relacionadas</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href="/pt/word-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="chart" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Palavras</h3><p class="text-xs text-text-muted">Meça o tamanho</p></a>
              <a href="/pt/title-case-converter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="tag" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Conversor para Título</h3><p class="text-xs text-text-muted">Refine cabeçalhos</p></a>
              <a href="/pt/character-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="text" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Contador de Caracteres</h3><p class="text-xs text-text-muted">Controle limites</p></a>
              <a href="/pt/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="book" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Legibilidade</h3><p class="text-xs text-text-muted">Avalie clareza</p></a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="case-converter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
