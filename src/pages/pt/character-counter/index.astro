---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CharacterCounterTool from '../../../components/CharacterCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
import Icon from '../../../components/Icon.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'O que é um contador de caracteres?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Um contador de caracteres mede todos os caracteres do texto, incluindo letras, números, espaços e pontuação. É útil para redes sociais, SEO e textos curtos.',
      },
    },
    {
      '@type': 'Question',
      name: 'Os espaços contam como caracteres?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim. Mostramos a contagem com espaços e sem espaços para que você escolha a métrica mais adequada ao seu objetivo.',
      },
    },
    {
      '@type': 'Question',
      name: 'Qual é o limite para X?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A referência geral é 280 caracteres por publicação de texto. Manter uma pequena margem ajuda em ajustes finais.',
      },
    },
    {
      '@type': 'Question',
      name: 'Isso serve para meta descrições?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim. A ferramenta ajuda a ajustar meta descrições, que costumam aparecer com cerca de 150 a 160 caracteres em buscadores.',
      },
    },
    {
      '@type': 'Question',
      name: 'Preciso de cadastro?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Não. A ferramenta é gratuita e pode ser usada imediatamente, sem conta e sem instalação.',
      },
    },
  ],
};
---

<BaseLayout 
  title="Contador de Caracteres - Verifica Limites para Redes Sociais" 
  description="Contador de caracteres gratuito. Conte caracteres com e sem espaços. Verifique limites para X, Instagram, LinkedIn e mais."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Contador de Caracteres</h1>
      <p class="text-base text-text-muted max-w-3xl">Conte caracteres com e sem espaços. Verifique limites para redes sociais, meta descrições e outras mensagens curtas.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CharacterCounterTool locale="pt" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Limites de Caracteres por Plataforma</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>X (Twitter)</span><span class="font-semibold">280 caracteres</span></li>
                <li class="flex justify-between"><span>Instagram Caption</span><span class="font-semibold">2,200 caracteres</span></li>
                <li class="flex justify-between"><span>LinkedIn Post</span><span class="font-semibold">3,000 caracteres</span></li>
                <li class="flex justify-between"><span>Meta Description</span><span class="font-semibold">160 caracteres</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal Para</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div><h3 class="font-semibold text-brand-pink mb-2">Times de Marketing</h3><p class="text-text-muted text-sm">Ajuste títulos, descrições e anúncios curtos para manter o melhor tamanho em campanhas e resultados de busca.</p></div>
              <div><h3 class="font-semibold text-brand-cyan mb-2">Gestores de Redes Sociais</h3><p class="text-text-muted text-sm">Controle o tamanho de posts para X, Instagram e LinkedIn antes de publicar e evitar cortes indesejados.</p></div>
              <div><h3 class="font-semibold text-brand-orange mb-2">Profissionais de SEO</h3><p class="text-text-muted text-sm">Verifique rapidamente se títulos e meta descrições estão dentro do intervalo recomendado para visibilidade.</p></div>
              <div><h3 class="font-semibold text-brand-pink mb-2">Estudantes e Profissionais</h3><p class="text-text-muted text-sm">Meça mensagens, resumos e apresentações curtas em que cada caractere precisa ser usado com intenção.</p></div>
            </div>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Dicas Práticas</h2>
            <ul class="space-y-4">
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Veja com e sem espaços:</strong> isso evita erro ao adaptar o texto a plataformas diferentes.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Deixe uma folga:</strong> alguns caracteres extras podem ser úteis para hashtags, menções e ajustes finais.</span></li>
              <li class="flex gap-3"><span class="text-brand-orange font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Otimize meta descrições:</strong> tente ficar por volta de 150–160 caracteres para evitar truncamento.</span></li>
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Enxugue com clareza:</strong> corte repetições e termos vagos antes de remover partes importantes da mensagem.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted"><strong>Revise antes de publicar:</strong> uma última checagem reduz o risco de texto cortado ou fora do padrão exigido.</span></li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Perguntas Frequentes</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">O que é um contador de caracteres?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Ele mede todos os caracteres de um texto, incluindo espaços e pontuação, o que é útil para SEO e redes sociais.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Os espaços contam?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Sim. Também mostramos a contagem sem espaços para comparação.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Qual é o limite para X?<span class="text-brand-orange group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">A referência geral é 280 caracteres por publicação de texto. Uma pequena margem é recomendada.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">É útil para SEO?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Sim. É especialmente útil para medir meta descrições e títulos curtos.</p></details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Preciso de cadastro?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Não. A ferramenta é gratuita e pode ser usada imediatamente.</p></details>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Ferramentas Relacionadas</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href={getLocalizedToolPath('pt', 'tweet-character-counter', 'character-counter')} class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="bird" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Tweets</h3><p class="text-xs text-text-muted">Ajuste textos para X</p></a>
              <a href={getLocalizedToolPath('pt', 'instagram-caption-counter', 'character-counter')} class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="camera" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Legenda do Instagram</h3><p class="text-xs text-text-muted">Refine suas legendas</p></a>
              <a href="/pt/word-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="chart" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Contador de Palavras</h3><p class="text-xs text-text-muted">Veja o tamanho total</p></a>
              <a href="/pt/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center"><div class="text-2xl mb-2"><Icon name="book" size={24} /></div><h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Legibilidade</h3><p class="text-xs text-text-muted">Avalie clareza</p></a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="character-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
