---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingTimeTool from '../../../components/ReadingTimeTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
import Icon from '../../../components/Icon.astro';
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Qual é a precisão da estimativa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'É uma referência útil baseada em velocidades médias.',
      },
    },
    {
      '@type': 'Question',
      name: 'Serve para apresentações?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim, principalmente com o tempo de fala.',
      },
    },
    {
      '@type': 'Question',
      name: 'Funciona para blogs?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim, ajuda a prever a duração do consumo do conteúdo.',
      },
    },
    {
      '@type': 'Question',
      name: 'Preciso medir de novo depois de editar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sim, porque pequenas mudanças alteram o tempo final.',
      },
    },
    {
      '@type': 'Question',
      name: 'Preciso de cadastro?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Não, a ferramenta é gratuita.',
      },
    },
  ],
};

---

<BaseLayout 
  title="Calculadora de Tempo de Leitura - Estima o Tempo de Leitura" 
  description="Estime o tempo de leitura e de fala do seu texto. Ideal para planejar o tamanho do conteúdo."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Calculadora de Tempo de Leitura</h1>
      <p class="text-base text-text-muted max-w-3xl">Estime o tempo de leitura e de fala do seu texto. Ideal para planejar o tamanho do conteúdo.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <ReadingTimeTool locale="pt" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidade</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espaço Publicitário</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Calculadora de Tempo de Leitura</h2>
            <p class="text-text-primary mb-4">A ferramenta estima tempo de leitura e de fala para ajudar você a ajustar o conteúdo ao contexto de uso.</p>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal Para</h2>
            <p class="text-text-primary">Artigos, newsletters, apresentações, roteiros e qualquer texto em que a duração afete a experiência.</p>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Dicas Práticas</h2>
            <ul class="space-y-4">
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Use tempo de leitura para consumo silencioso e tempo de fala para apresentações ou áudio.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Ajuste o tamanho ao canal.</span></li>
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Meça novamente após revisar.</span></li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Perguntas Frequentes</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Qual é a precisão da estimativa?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">É uma referência útil baseada em velocidades médias.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Serve para apresentações?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Sim, principalmente com o tempo de fala.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Funciona para blogs?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Sim, ajuda a prever a duração do consumo do conteúdo.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Preciso medir de novo depois de editar?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Sim, porque pequenas mudanças alteram o tempo final.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                Preciso de cadastro?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Não, a ferramenta é gratuita.</p>
            </details>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Ferramentas Relacionadas</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href="/pt/word-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="chart" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Palavras</h3>
              </a>
              <a href="/pt/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="text" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Verificador de Legibilidade</h3>
              </a>
              <a href="/pt/sentence-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="book" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Contador de Frases</h3>
              </a>
              <a href="/pt/character-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="pencil" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Caracteres</h3>
              </a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="reading-time" />
    </div>
  </main>

  <Footer />
</BaseLayout>
