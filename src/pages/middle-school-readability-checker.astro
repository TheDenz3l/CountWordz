---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadabilityCheckerTool from '../components/ReadabilityCheckerTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Middle School Readability Checker - Check Readability for Middle School Level" description="Free middle school readability checker. Check readability scores for middle school level content. Optimize for grades 6-8 reading level.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Middle School Readability Checker</h1><p class="text-base text-text-muted max-w-3xl">Check readability for middle school level content. Optimize your writing for grades 6-8 reading level.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadabilityCheckerTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Middle School Readability Standards</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>6th Grade</span><span class="font-semibold">Flesch 65-75</span></li><li class="flex justify-between"><span>7th Grade</span><span class="font-semibold">Flesch 60-70</span></li><li class="flex justify-between"><span>8th Grade</span><span class="font-semibold">Flesch 55-65</span></li><li class="flex justify-between"><span>Target Grade Level</span><span class="font-semibold">6-8</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Middle School Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Use age-appropriate vocabulary</li><li>Vary sentence length</li><li>Include engaging examples</li><li>Explain complex concepts clearly</li><li>Use transitions between ideas</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/elementary-readability-checker" class="text-brand-pink hover:underline">Elementary Readability Checker</a></li><li><a href="/high-school-readability-checker" class="text-brand-pink hover:underline">High School Readability Checker</a></li><li><a href="/readability-checker" class="text-brand-pink hover:underline">Readability Checker</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="readability" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
