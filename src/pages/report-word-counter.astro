---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Report Word Counter - Count Words for Reports" description="Free report word counter. Count words for business reports, annual reports, and technical reports. Track progress toward report word limits.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Report Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for business and technical reports. Track your progress toward report word requirements.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Report Word Count Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Business Report</span><span class="font-semibold">1,000-5,000 words</span></li><li class="flex justify-between"><span>Annual Report</span><span class="font-semibold">3,000-10,000 words</span></li><li class="flex justify-between"><span>Technical Report</span><span class="font-semibold">2,000-8,000 words</span></li><li class="flex justify-between"><span>Executive Summary</span><span class="font-semibold">200-500 words</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Report Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Use clear headings and subheadings</li><li>Include executive summary for long reports</li><li>Use visuals to complement text</li><li>Keep sentences concise and direct</li><li>Proofread carefully before submission</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/whitepaper-word-counter" class="text-brand-pink hover:underline">Whitepaper Word Counter</a></li><li><a href="/case-study-word-counter" class="text-brand-pink hover:underline">Case Study Word Counter</a></li><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
