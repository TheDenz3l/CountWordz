---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { VALID_LOCALES, normalizeLocale } from '../../lib/locale-routes';

export function getStaticPaths() {
  return VALID_LOCALES.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }));
}

const locale = normalizeLocale(Astro.params.locale);

const content = {
  en: {
    title: 'Privacy Policy',
    description: 'Learn how CountWordz handles text, analytics, and privacy across the site.',
    h1: 'Privacy Policy',
    updated: 'Last updated: April 1, 2026',
    intro: 'CountWordz is designed to work in the browser without requiring an account. This page explains what data we collect, what we do not collect, and how we handle basic site analytics.',
    sections: [
      {
        heading: 'Text you enter',
        body: 'Text entered into the tools is processed in your browser for counting, readability, comparison, and formatting features. We do not require you to create an account to use the tools.',
      },
      {
        heading: 'Analytics',
        body: 'We may use privacy-conscious analytics and search performance tools to understand site usage, popular pages, and product quality. Those tools may collect aggregate usage information such as page views, referrers, and device/browser metadata.',
      },
      {
        heading: 'Cookies and third-party services',
        body: 'The site may use cookies or similar technologies for analytics, advertising, and performance. Third-party services may apply their own privacy policies when they are loaded on the site.',
      },
      {
        heading: 'Your choices',
        body: 'You can stop using the site at any time, block cookies in your browser, or use browser privacy controls and content blockers if you prefer to limit third-party scripts.',
      },
      {
        heading: 'Contact',
        body: 'If you have a privacy question about CountWordz, contact the site operator through the appropriate support or contact channel associated with the site.',
      },
    ],
  },
  es: {
    title: 'Política de Privacidad',
    description: 'Conoce cómo CountWordz maneja el texto, las analíticas y la privacidad en todo el sitio.',
    h1: 'Política de Privacidad',
