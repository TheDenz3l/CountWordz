    intro: 'CountWordz foi criado para funcionar no navegador sem exigir conta. Esta página explica quais dados coletamos, quais dados não coletamos e como lidamos com análises básicas do site.',
    sections: [
      {
        heading: 'Texto inserido',
        body: 'O texto inserido nas ferramentas é processado no seu navegador para recursos de contagem, legibilidade, comparação e formatação. Não exigimos a criação de conta para usar as ferramentas.',
      },
      {
        heading: 'Análises',
        body: 'Podemos usar ferramentas de análise com foco em privacidade e ferramentas de desempenho em busca para entender o uso do site, as páginas populares e a qualidade do produto. Essas ferramentas podem coletar informações agregadas, como visualizações de página, origens de tráfego e metadados do navegador ou dispositivo.',
      },
      {
        heading: 'Cookies e serviços de terceiros',
        body: 'O site pode usar cookies ou tecnologias semelhantes para análises, publicidade e desempenho. Serviços de terceiros podem aplicar suas próprias políticas de privacidade quando são carregados no site.',
      },
      {
        heading: 'Suas escolhas',
        body: 'Você pode parar de usar o site a qualquer momento, bloquear cookies no navegador ou usar controles de privacidade e bloqueadores de conteúdo se preferir limitar scripts de terceiros.',
      },
      {
        heading: 'Contato',
        body: 'Se você tiver uma dúvida de privacidade sobre CountWordz, entre em contato com o operador do site pelo canal de suporte ou contato apropriado.',
      },
    ],
  },
};

const page = content[locale] ?? content.en;
---

<BaseLayout title={`${page.title} — CountWordz`} description={page.description}>
  <main class="layout-shell px-4 py-10">
    <div class="max-w-4xl mx-auto">
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-3">{page.h1}</h1>
        <p class="text-sm text-text-muted">{page.updated}</p>
      </header>

      <article class="bg-surface rounded-2xl border border-gray-100 p-6 md:p-8 space-y-8">
        <p class="text-text-primary leading-7">{page.intro}</p>

        {page.sections.map((section) => (
          <section>
            <h2 class="text-2xl font-display font-bold mb-3">{section.heading}</h2>
            <p class="text-text-primary leading-7">{section.body}</p>
          </section>
        ))}
      </article>
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>
