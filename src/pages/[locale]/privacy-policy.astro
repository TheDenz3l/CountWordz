    ],
  },
  fr: {
    title: 'Politique de Confidentialité',
    description: 'Découvrez comment CountWordz traite le texte, les analyses et la confidentialité sur le site.',
    h1: 'Politique de Confidentialité',
    updated: 'Dernière mise à jour : 1 avril 2026',
    intro: 'CountWordz est conçu pour fonctionner dans le navigateur sans nécessiter de compte. Cette page explique quelles données nous collectons, lesquelles nous ne collectons pas et comment nous gérons les analyses de base du site.',
