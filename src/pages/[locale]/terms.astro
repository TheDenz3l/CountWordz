---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { VALID_LOCALES, normalizeLocale } from '../../lib/locale-routes';

export function getStaticPaths() {
  return VALID_LOCALES.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }));
}

const locale = normalizeLocale(Astro.params.locale);

const content = {
  en: {
    title: 'Terms of Service',
    description: 'Read the terms for using CountWordz and its text analysis tools, including advertising and third-party services.',
    h1: 'Terms of Service',
    updated: 'Last updated: April 2, 2026',
    intro: 'These terms describe the conditions for using CountWordz. By using the site, you agree to use the tools lawfully and responsibly and to comply with these terms.',
    sections: [
      { heading: 'Use of the tools', body: 'CountWordz is provided for general writing, counting, formatting, and readability assistance. You are responsible for how you use the output and for reviewing any text before publishing or submitting it.' },
      { heading: 'No guarantee of uninterrupted service', body: 'We aim to keep the site available and accurate, but we do not guarantee uninterrupted access, permanent availability, or suitability for any specific legal, academic, or professional requirement.' },
      { heading: 'Advertising', body: 'CountWordz displays third-party advertisements, including ads served by Google AdSense. These ads help support the free tools on this site. By using the site, you acknowledge that advertisements will be displayed alongside the content. You agree not to click on advertisements artificially or use any means to inflate ad impressions or clicks.' },
      { heading: 'Third-party services', body: 'Some pages include analytics, advertising, fonts, or other third-party resources. Those third parties may apply their own terms and policies. We are not responsible for the content or practices of third-party services.' },
      { heading: 'Intellectual property', body: 'The content, design, and tools on CountWordz are the property of the site operator. You may not reproduce, distribute, or create derivative works from the site content without permission. Text you input into the tools remains your own property.' },
      { heading: 'Acceptable use', body: 'You agree not to misuse the site, interfere with its operation, attempt unauthorized access, or use the service in a way that violates applicable law or the rights of others.' },
      { heading: 'Limitation of liability', body: 'CountWordz is provided "as is" without warranties of any kind, either express or implied. We are not liable for any damages arising from your use of the site.' },
      { heading: 'Updates', body: 'These terms may change as the product evolves. Continued use of the site after changes are published means you accept the updated version.' },
    ],
  },
  es: {
    title: 'Términos de Servicio',
    description: 'Lee los términos para usar CountWordz y sus herramientas de análisis de texto, incluyendo publicidad y servicios de terceros.',
    h1: 'Términos de Servicio',
    updated: 'Última actualización: 2 de abril de 2026',
    intro: 'Estos términos describen las condiciones para usar CountWordz. Al usar el sitio, aceptas utilizar las herramientas de manera legal y responsable y cumplir con estos términos.',
    sections: [
      { heading: 'Uso de las herramientas', body: 'CountWordz se ofrece para asistencia general de escritura, conteo, formato y legibilidad. Eres responsable de cómo utilizas los resultados y de revisar cualquier texto antes de publicarlo o enviarlo.' },
      { heading: 'Sin garantía de servicio ininterrumpido', body: 'Buscamos mantener el sitio disponible y preciso, pero no garantizamos acceso ininterrumpido, disponibilidad permanente ni adecuación para requisitos legales, académicos o profesionales específicos.' },
      { heading: 'Publicidad', body: 'CountWordz muestra anuncios de terceros, incluidos anuncios servidos por Google AdSense. Estos anuncios ayudan a mantener las herramientas gratuitas en este sitio. Al usar el sitio, reconoces que se mostrarán anuncios junto al contenido. Aceptas no hacer clic en los anuncios de forma artificial ni usar medios para inflar impresiones o clics publicitarios.' },
      { heading: 'Servicios de terceros', body: 'Algunas páginas incluyen analíticas, publicidad, tipografías u otros recursos de terceros. Esos terceros pueden aplicar sus propios términos y políticas. No somos responsables del contenido o las prácticas de los servicios de terceros.' },
      { heading: 'Propiedad intelectual', body: 'El contenido, diseño y herramientas de CountWordz son propiedad del operador del sitio. No puedes reproducir, distribuir ni crear obras derivadas del contenido del sitio sin permiso. El texto que introduces en las herramientas sigue siendo tu propiedad.' },
      { heading: 'Uso aceptable', body: 'Aceptas no hacer un mal uso del sitio, no interferir con su funcionamiento, no intentar accesos no autorizados y no usar el servicio de una manera que viole la ley aplicable o los derechos de terceros.' },
      { heading: 'Limitación de responsabilidad', body: 'CountWordz se proporciona "tal cual" sin garantías de ningún tipo, ya sean expresas o implícitas. No somos responsables de los daños que surjan de tu uso del sitio.' },
      { heading: 'Actualizaciones', body: 'Estos términos pueden cambiar a medida que el producto evoluciona. El uso continuado del sitio después de publicar cambios significa que aceptas la versión actualizada.' },
    ],
  },
  fr: {
    title: 'Conditions d\'Utilisation',
    description: 'Consultez les conditions applicables à l\'utilisation de CountWordz et de ses outils, y compris la publicité et les services tiers.',
    h1: 'Conditions d\'Utilisation',
    updated: 'Dernière mise à jour : 2 avril 2026',
    intro: 'Ces conditions décrivent les règles pour utiliser CountWordz. En utilisant le site, vous acceptez d\'utiliser les outils de manière licite et responsable et de respecter ces conditions.',
    sections: [
      { heading: 'Utilisation des outils', body: 'CountWordz est fourni pour l\'assistance générale à l\'écriture, au comptage, au formatage et à la lisibilité. Vous êtes responsable de l\'usage que vous faites des résultats et de la révision de tout texte avant publication ou soumission.' },
      { heading: 'Aucune garantie de service ininterrompu', body: 'Nous cherchons à maintenir le site disponible et fiable, mais nous ne garantissons ni un accès ininterrompu, ni une disponibilité permanente, ni l\'adéquation du service à une exigence particulière.' },
      { heading: 'Publicité', body: 'CountWordz affiche des publicités de tiers, y compris des publicités diffusées par Google AdSense. Ces publicités contribuent au financement des outils gratuits de ce site. En utilisant le site, vous reconnaissez que des publicités seront affichées à côté du contenu. Vous acceptez de ne pas cliquer artificiellement sur les publicités ni d\'utiliser des moyens pour gonfler les impressions ou les clics publicitaires.' },
      { heading: 'Services tiers', body: 'Certaines pages incluent des analyses, de la publicité, des polices ou d\'autres ressources tierces. Ces tiers peuvent appliquer leurs propres conditions et politiques. Nous ne sommes pas responsables du contenu ou des pratiques des services tiers.' },
      { heading: 'Propriété intellectuelle', body: 'Le contenu, le design et les outils de CountWordz sont la propriété de l\'exploitant du site. Vous ne pouvez pas reproduire, distribuer ni créer des œuvres dérivées du contenu du site sans autorisation. Le texte que vous saisissez dans les outils reste votre propriété.' },
      { heading: 'Utilisation acceptable', body: 'Vous acceptez de ne pas détourner le site de son usage, de ne pas perturber son fonctionnement, de ne pas tenter d\'accès non autorisé et de ne pas utiliser le service de manière contraire à la loi ou aux droits d\'autrui.' },
      { heading: 'Limitation de responsabilité', body: 'CountWordz est fourni « en l\'état » sans garantie d\'aucune sorte, expresse ou implicite. Nous ne sommes pas responsables des dommages résultant de votre utilisation du site.' },
      { heading: 'Mises à jour', body: 'Ces conditions peuvent évoluer avec le produit. En continuant à utiliser le site après publication des modifications, vous acceptez la version mise à jour.' },
    ],
  },
  de: {
    title: 'Nutzungsbedingungen',
    description: 'Lesen Sie die Bedingungen für die Nutzung von CountWordz, einschließlich Werbung und Drittanbieter-Dienste.',
    h1: 'Nutzungsbedingungen',
    updated: 'Zuletzt aktualisiert: 2. April 2026',
    intro: 'Diese Bedingungen beschreiben die Regeln für die Nutzung von CountWordz. Durch die Nutzung der Website erklären Sie sich damit einverstanden, die Tools rechtmäßig und verantwortungsvoll zu verwenden.',
    sections: [
      { heading: 'Nutzung der Tools', body: 'CountWordz wird für allgemeine Unterstützung beim Schreiben, Zählen, Formatieren und bei der Lesbarkeit bereitgestellt. Sie sind dafür verantwortlich, wie Sie die Ergebnisse verwenden, und dafür, jeden Text vor Veröffentlichung selbst zu prüfen.' },
      { heading: 'Keine Gewähr für unterbrechungsfreien Dienst', body: 'Wir bemühen uns, die Website verfügbar und zuverlässig zu halten, garantieren jedoch weder ununterbrochenen Zugriff noch dauerhafte Verfügbarkeit oder Eignung für bestimmte Anforderungen.' },
      { heading: 'Werbung', body: 'CountWordz zeigt Werbung von Drittanbietern an, einschließlich Anzeigen, die von Google AdSense geschaltet werden. Diese Anzeigen helfen, die kostenlosen Tools auf dieser Website zu finanzieren. Durch die Nutzung der Website erkennen Sie an, dass Werbung neben dem Inhalt angezeigt wird. Sie stimmen zu, nicht künstlich auf Anzeigen zu klicken oder Mittel zu verwenden, um Anzeigenimpressionen oder Klicks aufzublähen.' },
      { heading: 'Drittanbieter-Dienste', body: 'Einige Seiten enthalten Analysen, Werbung, Schriftarten oder andere Drittanbieter-Ressourcen. Diese Drittanbieter können eigene Bedingungen und Richtlinien anwenden. Wir sind nicht verantwortlich für den Inhalt oder die Praktiken von Drittanbieter-Diensten.' },
      { heading: 'Geistiges Eigentum', body: 'Der Inhalt, das Design und die Tools auf CountWordz sind Eigentum des Website-Betreibers. Sie dürfen den Website-Inhalt nicht ohne Erlaubnis reproduzieren, verbreiten oder davon abgeleitete Werke erstellen. Text, den Sie in die Tools eingeben, bleibt Ihr Eigentum.' },
      { heading: 'Zulässige Nutzung', body: 'Sie stimmen zu, die Website nicht missbräuchlich zu verwenden, ihren Betrieb nicht zu stören, keinen unbefugten Zugriff zu versuchen und den Dienst nicht in einer Weise zu nutzen, die gegen geltendes Recht oder die Rechte Dritter verstößt.' },
      { heading: 'Haftungsbeschränkung', body: 'CountWordz wird „wie besehen" ohne jegliche ausdrückliche oder stillschweigende Gewährleistung bereitgestellt. Wir haften nicht für Schäden, die aus Ihrer Nutzung der Website entstehen.' },
      { heading: 'Änderungen', body: 'Diese Bedingungen können sich mit der Weiterentwicklung des Produkts ändern. Wenn Sie die Website nach Veröffentlichung von Änderungen weiter nutzen, akzeptieren Sie die aktualisierte Version.' },
    ],
  },
  pt: {
    title: 'Termos de Serviço',
    description: 'Leia os termos para usar CountWordz e suas ferramentas, incluindo publicidade e serviços de terceiros.',
    h1: 'Termos de Serviço',
    updated: 'Última atualização: 2 de abril de 2026',
    intro: 'Estes termos descrevem as condições para usar CountWordz. Ao usar o site, você concorda em utilizar as ferramentas de forma legal e responsável e em cumprir estes termos.',
    sections: [
      { heading: 'Uso das ferramentas', body: 'CountWordz é fornecido para apoio geral à escrita, contagem, formatação e legibilidade. Você é responsável pela forma como utiliza os resultados e por revisar qualquer texto antes de publicar ou enviar.' },
      { heading: 'Sem garantia de serviço ininterrupto', body: 'Buscamos manter o site disponível e confiável, mas não garantimos acesso ininterrupto, disponibilidade permanente ou adequação a requisitos específicos.' },
      { heading: 'Publicidade', body: 'CountWordz exibe anúncios de terceiros, incluindo anúncios veiculados pelo Google AdSense. Esses anúncios ajudam a manter as ferramentas gratuitas neste site. Ao usar o site, você reconhece que anúncios serão exibidos junto ao conteúdo. Você concorda em não clicar artificialmente nos anúncios ou usar meios para inflar impressões ou cliques publicitários.' },
      { heading: 'Serviços de terceiros', body: 'Algumas páginas incluem análises, publicidade, fontes ou outros recursos de terceiros. Esses terceiros podem aplicar seus próprios termos e políticas. Não somos responsáveis pelo conteúdo ou práticas de serviços de terceiros.' },
      { heading: 'Propriedade intelectual', body: 'O conteúdo, design e ferramentas do CountWordz são propriedade do operador do site. Você não pode reproduzir, distribuir ou criar obras derivadas do conteúdo do site sem permissão. O texto que você insere nas ferramentas permanece sua propriedade.' },
      { heading: 'Uso aceitável', body: 'Você concorda em não fazer mau uso do site, não interferir em seu funcionamento, não tentar acesso não autorizado e não usar o serviço de forma que viole a lei aplicável ou os direitos de terceiros.' },
      { heading: 'Limitação de responsabilidade', body: 'CountWordz é fornecido "como está" sem garantias de qualquer tipo, expressas ou implícitas. Não somos responsáveis por danos decorrentes do seu uso do site.' },
      { heading: 'Atualizações', body: 'Estes termos podem mudar conforme o produto evolui. O uso contínuo do site após a publicação de alterações significa que você aceita a versão atualizada.' },
    ],
  },
};

const page = content[locale] ?? content.en;
---

<BaseLayout title={`${page.title} — CountWordz`} description={page.description}>
  <main class="layout-shell px-4 py-10">
    <div class="max-w-4xl mx-auto">
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-3">{page.h1}</h1>
        <p class="text-sm text-text-muted">{page.updated}</p>
      </header>

      <article class="bg-surface rounded-2xl border border-gray-100 p-6 md:p-8 space-y-8">
        <p class="text-text-primary leading-7">{page.intro}</p>

        {page.sections.map((section) => (
          <section>
            <h2 class="text-2xl font-display font-bold mb-3">{section.heading}</h2>
            <p class="text-text-primary leading-7">{section.body}</p>
          </section>
        ))}
      </article>
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>
