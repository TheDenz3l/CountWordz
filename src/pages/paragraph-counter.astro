---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParagraphCounterTool from '../components/ParagraphCounterTool';
---
<BaseLayout title="Paragraph Counter - Count Paragraphs" description="Free paragraph counter tool. Count paragraphs and average words per paragraph.">
  <main class="container mx-auto px-4 py-8 max-w-7xl">
    <header class="mb-8"><h1 class="text-4xl md:text-6xl font-display font-bold tracking-tighter mb-3">Paragraph Counter</h1><p class="text-lg text-text-muted">Count paragraphs in your text.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden"><ParagraphCounterTool client:load /></div>
        <div class="mt-6 ad-slot-below-tool"><div class="bg-surface rounded-xl border border-gray-200 p-6 text-center"><p class="text-sm text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded-lg"><span class="text-gray-400">AdSense Ad Unit</span></div></div></div>
        <article class="mt-12 prose prose-lg"><h2>How to Use</h2><p>Paste text to count paragraphs. Paragraphs are separated by blank lines.</p><h2>Related Tools</h2><ul><li><a href="/word-counter">Word Counter</a></li><li><a href="/sentence-counter">Sentence Counter</a></li></ul></article>
      </div>
      <aside class="hidden lg:block lg:col-span-1"><div class="sticky top-8"><div class="ad-slot-sidebar"><div class="bg-surface rounded-xl border border-gray-200 p-6 text-center"><p class="text-sm text-text-muted mb-2">Advertisement</p><div class="min-h-[600px] flex items-center justify-center bg-gray-50 rounded-lg"><span class="text-gray-400">AdSense Sidebar Ad</span></div></div></div></div></aside>
    </div>
  </main>
</BaseLayout>
