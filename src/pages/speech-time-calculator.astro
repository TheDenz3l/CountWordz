---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingTimeTool from '../components/ReadingTimeTool';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
---
<BaseLayout title="Speech Time Calculator - Estimate How Long Your Speech Will Take" description="Free speech time calculator. Estimate speaking time for speeches, presentations, and scripts based on word count.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Speech Time Calculator</h1><p class="text-base text-text-muted max-w-3xl">Estimate speaking time for speeches and presentations. Plan your delivery based on word count and speaking pace.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadingTimeTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Speaking Pace Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Slow pace</span><span class="font-semibold">100-120 WPM</span></li><li class="flex justify-between"><span>Average pace</span><span class="font-semibold">130-150 WPM</span></li><li class="flex justify-between"><span>Fast pace</span><span class="font-semibold">160-180 WPM</span></li></ul><p class="text-sm text-text-muted mt-3">Most speeches are delivered at 130-150 words per minute. Adjust for your natural pace and audience.</p></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Speech Length Reference</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li><strong>1 minute:</strong> 130-150 words</li><li><strong>5 minutes:</strong> 650-750 words</li><li><strong>10 minutes:</strong> 1300-1500 words</li><li><strong>15 minutes:</strong> 1950-2250 words</li><li><strong>20 minutes:</strong> 2600-3000 words</li><li><strong>TED Talk (18 min):</strong> 2300-2700 words</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">FAQs</h2><h3 class="text-xl font-display font-semibold mt-4 mb-2">How do I calculate speech time?</h3><p class="text-text-primary mb-4">Divide your word count by your speaking pace (words per minute). For example, 1500 words ÷ 150 WPM = 10 minutes.</p><h3 class="text-xl font-display font-semibold mt-4 mb-2">Should I speak faster to fit more content?</h3><p class="text-text-primary mb-4">No. Speaking too fast reduces comprehension. It's better to cut content than to rush your delivery.</p></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li><li><a href="/speech-word-counter" class="text-brand-pink hover:underline">Speech Word Counter</a></li><li><a href="/sentence-counter" class="text-brand-pink hover:underline">Sentence Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="reading-time" />
    </div>
  </main>
  <!-- Footer Ad Banner -->
  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
