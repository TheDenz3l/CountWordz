---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Product Description Word Counter - Count Words for Product Descriptions" description="Free product description word counter. Count words for e-commerce product descriptions. Optimize product description length for conversions and SEO.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Product Description Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for product descriptions. Optimize your e-commerce product descriptions for conversions and search visibility.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Product Description Length Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Short Description</span><span class="font-semibold">50-100 words</span></li><li class="flex justify-between"><span>Standard Description</span><span class="font-semibold">150-300 words</span></li><li class="flex justify-between"><span>Detailed Description</span><span class="font-semibold">400-600 words</span></li><li class="flex justify-between"><span>Meta Description</span><span class="font-semibold">150-160 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Product Description Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Focus on benefits, not just features</li><li>Use sensory and emotional language</li><li>Include relevant keywords for SEO</li><li>Use bullet points for scannability</li><li>Address common customer questions</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/meta-description-counter" class="text-brand-pink hover:underline">Meta Description Counter</a></li><li><a href="/email-word-counter" class="text-brand-pink hover:underline">Email Word Counter</a></li><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
