---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
---
<BaseLayout title="Article Word Counter - Count Words for Articles & Blog Posts" description="Free article word counter. Count words for articles, blog posts, and online content. Track progress toward publishing goals.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Article Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for articles and blog posts. Track your writing progress toward publishing goals.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Article Word Count Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>News article</span><span class="font-semibold">500-800 words</span></li><li class="flex justify-between"><span>Feature article</span><span class="font-semibold">1000-2000 words</span></li><li class="flex justify-between"><span>Long-form article</span><span class="font-semibold">2000-5000 words</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li><li><a href="/blog-reading-time" class="text-brand-pink hover:underline">Blog Reading Time</a></li><li><a href="/readability-checker" class="text-brand-pink hover:underline">Readability Checker</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <!-- Footer Ad Banner -->
  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
