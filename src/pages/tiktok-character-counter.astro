---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="TikTok Character Counter - Count Characters for TikTok Bios and Captions" 
  description="Free TikTok character counter. Count characters for TikTok bios (80 chars), captions (2200 chars), and comments. Optimize your TikTok content."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">TikTok Character Counter</h1>
      <p class="text-base text-text-muted max-w-3xl">Count characters for TikTok bios, captions, and comments. Stay within TikTok's character limits to maximize your content's impact.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CharacterCounterTool client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Advertisement</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">AdSense Banner</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Advertisement</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">AdSense Square</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">TikTok Character Limits 2026</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>Bio</span><span class="font-semibold">80 characters</span></li>
                <li class="flex justify-between"><span>Video Caption</span><span class="font-semibold">2,200 characters</span></li>
                <li class="flex justify-between"><span>Comment</span><span class="font-semibold">150 characters</span></li>
                <li class="flex justify-between"><span>Username</span><span class="font-semibold">24 characters</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">TikTok Bio Tips</h2>
            <ul class="list-disc list-inside space-y-2 text-text-primary mb-4">
              <li>Use all 80 characters — every character counts</li>
              <li>Include a call-to-action (follow, click link, etc.)</li>
              <li>Add relevant emojis to save space and add personality</li>
              <li>Include your niche or what you post about</li>
              <li>Use line breaks for readability (press return)</li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Caption Best Practices</h2>
            <ul class="list-disc list-inside space-y-2 text-text-primary mb-4">
              <li>Hook viewers in the first line (shown in feed preview)</li>
              <li>Use 3-5 relevant hashtags (not too many)</li>
              <li>Ask questions to encourage comments</li>
              <li>Include a CTA (like, follow, share, comment)</li>
              <li>Keep it concise — TikTok is fast-paced</li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">FAQs</h2>
            <h3 class="text-xl font-display font-semibold mt-4 mb-2">How long should my TikTok bio be?</h3>
            <p class="text-text-primary mb-4">TikTok bios are limited to 80 characters. Use all of them wisely to describe who you are and what viewers can expect from your content.</p>
            <h3 class="text-xl font-display font-semibold mt-4 mb-2">Do hashtags count toward the character limit?</h3>
            <p class="text-text-primary mb-4">Yes, hashtags count as regular characters. A long hashtag can use up significant space in your caption.</p>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2>
            <ul class="space-y-2">
              <li><a href="/instagram-caption-counter" class="text-brand-pink hover:underline">Instagram Caption Counter</a></li>
              <li><a href="/youtube-description-counter" class="text-brand-pink hover:underline">YouTube Description Counter</a></li>
              <li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="character-counter" />
    </div>
  </main>

  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
