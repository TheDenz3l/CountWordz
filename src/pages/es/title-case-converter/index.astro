---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CaseConverterTool from '../../../components/CaseConverterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Convertidor a Título - Convierte a Formato de Título" 
  description="Convertidor a título gratuito. Convierte texto a formato de título siguiendo guías de estilo APA, MLA, Chicago y AP."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Convertidor a Título</h1>
      <p class="text-base text-text-muted max-w-3xl">Convierte texto a formato de título apropiado siguiendo guías de estilo estándar.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CaseConverterTool locale="es" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Reglas de Formato de Título</h2>
            <p class="text-text-primary mb-4">Las palabras principales se capitalizan. Las palabras menores (artículos, preposiciones cortas, conjunciones) permanecen en minúsculas a menos que sean la primera palabra.</p>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Herramientas Relacionadas</h2>
            <ul class="space-y-2">
              <li><a href="/es/case-converter" class="text-brand-pink hover:underline">Convertidor de Mayúsculas</a></li>
              <li><a href="/es/word-counter" class="text-brand-pink hover:underline">Contador de Palabras</a></li>
              <li><a href="/es/character-counter" class="text-brand-pink hover:underline">Contador de Caracteres</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="title-case" />
    </div>
  </main>

  <Footer />
</BaseLayout>
