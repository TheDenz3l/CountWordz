---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getLocalizedLongTailPath, getLocalizedStaticPath, getLocalizedToolPath, getLocaleHomePath } from '../../lib/locale-routes';
import { getLongTailDirectoryEntries, readabilityDirectorySlugs, readingTimeDirectorySlugs } from '../../lib/tools-directory';

const locale = 'es';
const readabilityTools = getLongTailDirectoryEntries(locale, readabilityDirectorySlugs);
const readingTimeTools = getLongTailDirectoryEntries(locale, readingTimeDirectorySlugs);

const coreTools = [
  { slug: 'word-counter', title: 'Contador de Palabras', description: 'Cuenta palabras, caracteres, oraciones y más', accent: 'text-brand-pink' },
  { slug: 'character-counter', title: 'Contador de Caracteres', description: 'Verifica límites de caracteres para redes sociales', accent: 'text-brand-cyan' },
  { slug: 'sentence-counter', title: 'Contador de Oraciones', description: 'Cuenta oraciones y analiza estructura', accent: 'text-brand-orange' },
  { slug: 'paragraph-counter', title: 'Contador de Párrafos', description: 'Cuenta párrafos y promedio de palabras', accent: 'text-brand-pink' },
  { slug: 'syllable-counter', title: 'Contador de Sílabas', description: 'Cuenta sílabas en palabras y texto', accent: 'text-brand-cyan' },
  { slug: 'reading-time-calculator', title: 'Calculadora de Tiempo de Lectura', description: 'Estima tiempo de lectura y habla', accent: 'text-brand-orange' },
  { slug: 'case-converter', title: 'Convertidor de Mayúsculas', description: 'Convierte texto entre diferentes formatos', accent: 'text-brand-pink' },
  { slug: 'title-case-converter', title: 'Convertidor a Título', description: 'Convierte a formato de título apropiado', accent: 'text-brand-cyan' },
  { slug: 'readability-checker', title: 'Verificador de Legibilidad', description: 'Mide puntuaciones de legibilidad', accent: 'text-brand-orange' },
  { slug: 'keyword-density-checker', title: 'Densidad de Palabras Clave', description: 'Analiza frecuencia de palabras y frases', accent: 'text-brand-pink' },
  { slug: 'text-compare-tool', title: 'Comparador de Texto', description: 'Compara dos textos y resalta diferencias', accent: 'text-brand-cyan' },
  { slug: 'paragraph-rewriter', title: 'Reescritor de Párrafos', description: 'Obtén sugerencias para mejorar escritura', accent: 'text-brand-orange' },
];

const platformTools = [
  { slug: 'tweet-character-counter', title: 'Contador de Tweets', description: 'X/Twitter (280 caracteres)', category: 'character-counter' },
  { slug: 'instagram-caption-counter', title: 'Instagram Caption', description: '2,200 caracteres', category: 'character-counter' },
  { slug: 'linkedin-post-counter', title: 'LinkedIn Post', description: '3,000 caracteres' },
  { slug: 'tiktok-character-counter', title: 'TikTok', description: 'Bio y pies de foto' },
  { slug: 'facebook-post-counter', title: 'Facebook Post', description: '63,206 caracteres' },
  { slug: 'pinterest-pin-counter', title: 'Pinterest Pin', description: 'Título y descripción' },
  { slug: 'youtube-title-counter', title: 'Título de YouTube', description: '100 caracteres' },
  { slug: 'youtube-tag-counter', title: 'Etiquetas de YouTube', description: '500 caracteres' },
  { slug: 'email-subject-counter', title: 'Asunto de Email', description: '60-70 caracteres' },
  { slug: 'linkedin-headline-counter', title: 'Titular de LinkedIn', description: '220 caracteres' },
  { slug: 'meta-title-counter', title: 'Meta Título', description: '60 caracteres (SEO)' },
  { slug: 'instagram-story-counter', title: 'Historia de Instagram', description: '250 caracteres' },
  { slug: 'tweet-thread-counter', title: 'Hilo de Tweets', description: '280 por tweet' },
  { slug: 'whatsapp-message-counter', title: 'WhatsApp', description: '4,096 caracteres' },
  { slug: 'telegram-message-counter', title: 'Telegram', description: '4,096 caracteres' },
  { slug: 'discord-message-counter', title: 'Discord', description: '2,000 caracteres' },
  { slug: 'reddit-post-counter', title: 'Post de Reddit', description: '300 (título), 40k (post)' },
  { slug: 'sms-character-counter', title: 'SMS', description: '160 caracteres' },
  { slug: 'tiktok-bio-counter', title: 'Bio de TikTok', description: '80 caracteres' },
];

const wordTools = [
  { slug: 'essay-word-counter', title: 'Contador de Ensayos', description: 'Para estudiantes y escritores', category: 'word-counter' },
  { slug: 'resume-word-counter', title: 'Contador de Currículums', description: 'Para solicitudes de empleo', category: 'word-counter' },
  { slug: 'cover-letter-word-counter', title: 'Carta de Presentación', description: 'Para solicitudes', category: 'word-counter' },
  { slug: 'college-essay-word-counter', title: 'Ensayo Universitario', description: 'Para admisiones', category: 'word-counter' },
  { slug: 'speech-word-counter', title: 'Contador de Discursos', description: 'Para presentaciones' },
  { slug: 'paragraph-word-counter', title: 'Conteo por Párrafo', description: 'Por párrafo' },
  { slug: 'article-word-counter', title: 'Contador de Artículos', description: 'Para posts de blog' },
  { slug: 'thesis-word-counter', title: 'Contador de Tesis', description: 'Para trabajos académicos' },
  { slug: 'dissertation-word-counter', title: 'Disertación', description: 'Para tesis doctorales' },
  { slug: 'grant-proposal-word-counter', title: 'Propuesta de Subvención', description: 'Para solicitudes' },
  { slug: 'book-chapter-word-counter', title: 'Capítulo de Libro', description: 'Para autores' },
  { slug: 'blog-post-word-counter', title: 'Post de Blog', description: 'Para bloggers' },
  { slug: 'email-word-counter', title: 'Contador de Emails', description: 'Para emails' },
  { slug: 'report-word-counter', title: 'Informe', description: 'Para informes empresariales' },
  { slug: 'whitepaper-word-counter', title: 'Whitepaper', description: 'Para marketing' },
  { slug: 'script-word-counter', title: 'Guion', description: 'Para video/cine' },
  { slug: 'podcast-script-word-counter', title: 'Guion de Podcast', description: 'Para podcasts' },
  { slug: 'youtube-script-word-counter', title: 'Guion de YouTube', description: 'Para videos' },
  { slug: 'presentation-word-counter', title: 'Presentación', description: 'Para diapositivas' },
  { slug: 'case-study-word-counter', title: 'Estudio de Caso', description: 'Para marketing' },
  { slug: 'press-release-word-counter', title: 'Comunicado de Prensa', description: 'Para medios' },
  { slug: 'product-description-word-counter', title: 'Descripción de Producto', description: 'Para e-commerce' },
];
---

<BaseLayout 
  title="Todas las Herramientas de Texto - Lista Completa de 103 Herramientas Gratuitas" 
  description="Lista completa de las 103 herramientas de texto gratuitas en CountWordz. Explora por categoría: contadores de palabras, contadores de caracteres, verificadores de legibilidad, calculadoras de tiempo de lectura y más."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-8">
      <h1 class="text-4xl md:text-6xl font-display font-bold tracking-tighter text-text-primary mb-3">Todas las Herramientas de Texto</h1>
      <p class="text-lg text-text-muted max-w-3xl">Explora las 103 herramientas de texto gratuitas organizadas por categoría. Encuentra la herramienta perfecta para tu escritura, edición y optimización de contenido.</p>
    </header>

    <section class="py-6 bg-gray-50 mb-8">
      <div class="layout-shell px-4">
        <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
          <p class="text-xs text-text-muted mb-2">Publicidad</p>
          <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
            <span class="text-gray-400 text-sm">Espacio Publicitario (728x90)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-pink">Herramientas Principales</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {coreTools.map((tool) => (
          <a href={getLocalizedStaticPath(locale, tool.slug)} class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
            <h3 class={`font-semibold ${tool.accent}`}>{tool.title}</h3>
            <p class="text-sm text-text-muted mt-1">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="py-6 bg-white mb-12">
      <div class="layout-shell px-4">
        <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
          <p class="text-xs text-text-muted mb-2">Publicidad</p>
          <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
            <span class="text-gray-400 text-sm">Espacio Publicitario (300x250)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-cyan">Contadores de Caracteres por Plataforma</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {platformTools.map((tool) => (
          <a href={getLocalizedLongTailPath(locale, tool.slug, tool.category)} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-cyan transition-all">
            <h3 class="font-medium text-brand-cyan">{tool.title}</h3>
            <p class="text-xs text-text-muted mt-1">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-orange">Contadores de Palabras por Tipo de Documento</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {wordTools.map((tool) => (
          <a href={getLocalizedLongTailPath(locale, tool.slug, tool.category)} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-orange transition-all">
            <h3 class="font-medium text-brand-orange">{tool.title}</h3>
            <p class="text-xs text-text-muted mt-1">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-pink">Verificadores de Legibilidad por Industria</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {readabilityTools.map((tool) => (
          <a href={getLocalizedToolPath(locale, tool.slug)} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink transition-all">
            <h3 class="font-medium text-brand-pink">{tool.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-cyan">Calculadoras de Tiempo de Lectura</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {readingTimeTools.map((tool) => (
          <a href={getLocalizedToolPath(locale, tool.slug)} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-cyan transition-all">
            <h3 class="font-medium text-brand-cyan">{tool.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <section class="py-6 bg-gray-50 mb-12">
      <div class="layout-shell px-4">
        <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
          <p class="text-xs text-text-muted mb-2">Publicidad</p>
          <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
            <span class="text-gray-400 text-sm">Espacio Publicitario (728x90)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-brand-cream rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-display font-bold mb-4">103 Herramientas de Texto Gratuitas</h2>
      <p class="text-text-muted mb-6 max-w-2xl mx-auto">Todas las herramientas son 100% gratuitas, funcionan en tu navegador y no requieren registro. Comienza a usar cualquier herramienta arriba instantáneamente.</p>
      <a href={getLocaleHomePath(locale)} class="inline-block px-8 py-3 bg-brand-pink text-white rounded-lg font-semibold hover:bg-opacity-90 transition-all">Volver al Inicio</a>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
