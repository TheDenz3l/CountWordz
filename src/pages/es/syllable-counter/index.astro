---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SyllableCounterTool from '../../../components/SyllableCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import Icon from '../../../components/Icon.astro';
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cómo se cuentan las sílabas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Se estiman con reglas lingüísticas y patrones vocálicos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es exacto al 100%?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No siempre; algunas palabras irregulares requieren revisión humana.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Sirve para poesía?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, es muy útil para medir ritmo y estructura.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Ayuda con la legibilidad?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, porque muchas fórmulas consideran sílabas por palabra.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Necesito registrarme?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No.',
      },
    },
  ],
};

---

<BaseLayout 
  title="Contador de Sílabas - Cuenta Sílabas en Palabras" 
  description="Cuenta sílabas en palabras y textos. Ideal para legibilidad, poesía y ritmo."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Contador de Sílabas</h1>
      <p class="text-base text-text-muted max-w-3xl">Cuenta sílabas en palabras y textos. Ideal para legibilidad, poesía y ritmo.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <SyllableCounterTool locale="es" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Contador de Sílabas</h2>
            <p class="text-text-primary mb-4">El contador estima sílabas para ayudarte con análisis de legibilidad, escritura métrica y revisión de complejidad de palabras.</p>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal Para</h2>
            <p class="text-text-primary">Poesía, canciones, análisis de legibilidad y textos donde el ritmo o la complejidad léxica importan.</p>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Consejos Prácticos</h2>
            <ul class="space-y-4">
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Trata el resultado como estimación.</span></li>
              <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Úsalo junto al verificador de legibilidad.</span></li>
              <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span class="text-text-muted">Revisa manualmente palabras poco comunes o nombres propios.</span></li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Preguntas Frecuentes</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Cómo se cuentan las sílabas?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Se estiman con reglas lingüísticas y patrones vocálicos.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Es exacto al 100%?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">No siempre; algunas palabras irregulares requieren revisión humana.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Sirve para poesía?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Sí, es muy útil para medir ritmo y estructura.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Ayuda con la legibilidad?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Sí, porque muchas fórmulas consideran sílabas por palabra.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Necesito registrarme?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">No.</p>
            </details>
          </section>

          <div class="my-6 ad-slot-bottom">
            <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
              <p class="text-xs text-text-muted mb-2">Publicidad</p>
              <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
                <span class="text-gray-400 text-sm">Espacio Publicitario</span>
              </div>
            </div>
          </div>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Herramientas Relacionadas</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href="/es/word-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="chart" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Palabras</h3>
              </a>
              <a href="/es/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="text" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Verificador de Legibilidad</h3>
              </a>
              <a href="/es/character-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="book" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Contador de Caracteres</h3>
              </a>
              <a href="/es/sentence-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="pencil" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Oraciones</h3>
              </a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="syllable-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
