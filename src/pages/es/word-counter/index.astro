---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WordCounterTool from '../../../components/WordCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import Icon from '../../../components/Icon.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cómo cuenta las palabras?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Contamos palabras dividiendo el texto por espacios y filtrando cadenas vacías. Las palabras con guión como "bien conocido" cuentan como una palabra.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es preciso el tiempo de lectura?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El tiempo de lectura se calcula basándose en una velocidad promedio de 200 palabras por minuto. El tiempo real puede variar según la complejidad del texto.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Los caracteres incluyen espacios?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Mostramos ambos conteos: caracteres con espacios y caracteres sin espacios. Esto es útil para diferentes plataformas que tienen distintos requisitos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo usar esto para ensayos académicos?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, es perfecto para ensayos. Muestra conteo de palabras, oraciones y párrafos, además del tiempo de lectura estimado para ayudarte a cumplir con los requisitos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Necesito registrarme para usar esta herramienta?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, es completamente gratuita y no requiere registro. Solo pega tu texto y comienza a contar inmediatamente.',
      },
    },
  ],
};
---

<BaseLayout 
  title="Contador de Palabras - Cuenta Palabras, Caracteres y Más" 
  description="Contador de palabras gratuito. Cuenta palabras, caracteres, oraciones, párrafos y estima el tiempo de lectura en tiempo real."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Contador de Palabras</h1>
      <p class="text-base text-text-muted max-w-3xl">Cuenta palabras, caracteres, oraciones y más en tiempo real. Perfecto para ensayos, currículums, publicaciones y scripts.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <WordCounterTool locale="es" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Cómo Usar el Contador de Palabras</h2>
            <p class="text-text-primary mb-4">Simplemente pega o escribe tu texto arriba. El contador mostrará instantáneamente:</p>
            <ul class="list-disc list-inside space-y-2 text-text-primary">
              <li><strong>Conteo de palabras</strong> — Número total de palabras</li>
              <li><strong>Conteo de caracteres</strong> — Con y sin espacios</li>
              <li><strong>Conteo de oraciones</strong> — Número de oraciones</li>
              <li><strong>Conteo de párrafos</strong> — Número de párrafos</li>
              <li><strong>Tiempo de lectura</strong> — Tiempo estimado para leer</li>
              <li><strong>Tiempo de habla</strong> — Tiempo estimado para hablar</li>
            </ul>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Ideal Para</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h3 class="font-semibold text-brand-pink mb-2">Estudiantes y Educadores</h3>
                <p class="text-text-muted text-sm">Verifica el conteo de palabras de ensayos, analiza niveles de lectura y asegura que las tareas cumplan con los requisitos. Perfecto para escritura académica y planificación de clases.</p>
              </div>
              <div>
                <h3 class="font-semibold text-brand-cyan mb-2">Creadores de Contenido</h3>
                <p class="text-text-muted text-sm">Optimiza publicaciones de blogs, leyendas de redes sociales y copias de marketing. Mantente dentro de los límites de caracteres para X, Instagram, LinkedIn y más.</p>
              </div>
              <div>
                <h3 class="font-semibold text-brand-orange mb-2">Escritores Profesionales</h3>
                <p class="text-text-muted text-sm">Rastrea metas de escritura, analiza legibilidad y mantén calidad consistente de contenido. Ideal para periodistas, redactores publicitarios y autores.</p>
              </div>
              <div>
                <h3 class="font-semibold text-brand-pink mb-2">Especialistas en SEO</h3>
                <p class="text-text-muted text-sm">Asegura que las meta descripciones, etiquetas de título y longitudes de contenido sigan las mejores prácticas de SEO. Mejora las clasificaciones de búsqueda con contenido optimizado.</p>
              </div>
            </div>
          </section>

          <section class="mb-6 bg-surface rounded-2xl p-8 border border-gray-100">
            <h2 class="text-2xl font-display font-bold mb-6 text-center">Consejos Prácticos</h2>
            <ul class="space-y-4">
              <li class="flex gap-3">
                <span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span>
                <span class="text-text-muted"><strong>Usa la herramienta correcta para tu objetivo:</strong> Contador de palabras para ensayos, contador de caracteres para redes sociales, verificador de legibilidad para publicaciones de blog.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span>
                <span class="text-text-muted"><strong>Verifica las puntuaciones de legibilidad:</strong> Apunta a una puntuación Flesch de 60-70 para audiencias generales. Puntuaciones más bajas indican texto más complejo.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-orange font-bold"><Icon name="check" size={18} /></span>
                <span class="text-text-muted"><strong>Monitorea la longitud de las oraciones:</strong> Una longitud promedio de 15-20 palabras mejora la legibilidad. Usa el contador de oraciones para rastrear esto.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span>
                <span class="text-text-muted"><strong>Optimiza para tu plataforma:</strong> Cada plataforma social tiene diferentes límites. Usa nuestros contadores específicos para X, Instagram y LinkedIn.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span>
                <span class="text-text-muted"><strong>Revisa el tiempo de lectura:</strong> Las publicaciones de blog deben tener un tiempo de lectura de 3-7 minutos para un compromiso óptimo. Ajusta la longitud del contenido en consecuencia.</span>
              </li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Preguntas Frecuentes</h2>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Cómo cuenta las palabras?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Contamos palabras dividiendo el texto por espacios y filtrando cadenas vacías. Las palabras con guión como "bien conocido" cuentan como una palabra.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Es preciso el tiempo de lectura?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">El tiempo de lectura se calcula basándose en una velocidad promedio de 200 palabras por minuto. El tiempo real puede variar según la complejidad del texto.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Los caracteres incluyen espacios?
                <span class="text-brand-orange group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Mostramos ambos conteos: caracteres con espacios y caracteres sin espacios. Esto es útil para diferentes plataformas que tienen distintos requisitos.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Puedo usar esto para ensayos académicos?
                <span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">Sí, es perfecto para ensayos. Muestra conteo de palabras, oraciones y párrafos, además del tiempo de lectura estimado para ayudarte a cumplir con los requisitos.</p>
            </details>
            <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4">
              <summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">
                ¿Necesito registrarme para usar esta herramienta?
                <span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-text-muted mt-4">No, es completamente gratuita y no requiere registro. Solo pega tu texto y comienza a contar inmediatamente.</p>
            </details>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Herramientas Relacionadas</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <a href="/es/character-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="text" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Contador de Caracteres</h3>
                <p class="text-xs text-text-muted">Verifica límites de caracteres</p>
              </a>
              <a href="/es/sentence-counter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="note" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-cyan">Contador de Oraciones</h3>
                <p class="text-xs text-text-muted">Cuenta oraciones en tu texto</p>
              </a>
              <a href="/es/readability-checker" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="book" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-orange">Verificador de Legibilidad</h3>
                <p class="text-xs text-text-muted">Mide la facilidad de lectura</p>
              </a>
              <a href="/es/case-converter" class="bg-surface p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow block text-center">
                <div class="text-2xl mb-2"><Icon name="text" size={24} /></div>
                <h3 class="text-sm font-display font-semibold mb-1 text-brand-pink">Convertidor de Mayúsculas</h3>
                <p class="text-xs text-text-muted">Convierte entre diferentes casos</p>
              </a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar category="word-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
