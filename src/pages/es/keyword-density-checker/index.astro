---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import KeywordDensityChecker from '../../../components/KeywordDensityChecker';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
---

<BaseLayout 
  title="Densidad de Palabras Clave - Analiza Frecuencia de Palabras" 
  description="Verificador de densidad de palabras clave gratuito. Analiza frecuencia de palabras y frases para optimización SEO."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Densidad de Palabras Clave</h1>
      <p class="text-base text-text-muted max-w-3xl">Analiza la frecuencia de palabras y frases en tu texto. Optimiza tu contenido para SEO evitando el relleno de palabras clave.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <KeywordDensityChecker locale="es" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Densidad de Palabras Clave Óptima</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>Óptimo</span><span class="font-semibold">1-2%</span></li>
                <li class="flex justify-between"><span>Aceptable</span><span class="font-semibold">2-3%</span></li>
                <li class="flex justify-between"><span>Demasiado alto</span><span class="font-semibold">3%+</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Herramientas Relacionadas</h2>
            <ul class="space-y-2">
              <li><a href="/es/word-counter" class="text-brand-pink hover:underline">Contador de Palabras</a></li>
              <li><a href="/es/readability-checker" class="text-brand-pink hover:underline">Verificador de Legibilidad</a></li>
              <li><a href={getLocalizedToolPath('es', 'seo-content-readability-checker')} class="text-brand-pink hover:underline">Legibilidad SEO</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="keyword-density" />
    </div>
  </main>

  <Footer />
</BaseLayout>