---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ParagraphRewriter from '../../../components/ParagraphRewriter';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Reescritor de Párrafos - Mejora la Claridad de tu Escritura" 
  description="Herramienta de reescritura de párrafos gratuita. Obtén sugerencias para mejorar la claridad, legibilidad y estructura de tu escritura."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Reescritor de Párrafos</h1>
      <p class="text-base text-text-muted max-w-3xl">Obtén sugerencias inteligentes para mejorar tu escritura. Corrige voz pasiva, acorta oraciones largas, simplifica palabras complejas y mejora la legibilidad.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <ParagraphRewriter locale="es" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Qué Mejora Esta Herramienta</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li><strong>Voz pasiva</strong> — Sugiere cambiar a voz activa</li>
                <li><strong>Oraciones largas</strong> — Recomienda dividir oraciones de más de 25 palabras</li>
                <li><strong>Palabras complejas</strong> — Sugiere alternativas más simples</li>
                <li><strong>Repetición</strong> — Identifica palabras usadas en exceso</li>
                <li><strong>Legibilidad</strong> — Muestra puntuaciones de legibilidad mejoradas</li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Herramientas Relacionadas</h2>
            <ul class="space-y-2">
              <li><a href="/es/word-counter" class="text-brand-pink hover:underline">Contador de Palabras</a></li>
              <li><a href="/es/text-compare-tool" class="text-brand-pink hover:underline">Comparador de Texto</a></li>
              <li><a href="/es/readability-checker" class="text-brand-pink hover:underline">Verificador de Legibilidad</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="paragraph-rewriter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
