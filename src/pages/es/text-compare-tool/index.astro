---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TextDiffTool from '../../../components/TextDiffTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Comparador de Texto - Compara Dos Textos" 
  description="Herramienta de comparación de texto gratuita. Compara dos textos lado a lado y resalta diferencias. Ve palabras agregadas, eliminadas y cambiadas."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Comparador de Texto</h1>
      <p class="text-base text-text-muted max-w-3xl">Compara dos textos lado a lado y resalta las diferencias. Rastrea cambios entre versiones de documentos con precisión a nivel de palabra.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <TextDiffTool locale="es" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicidad</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espacio Publicitario</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Cómo Funciona</h2>
            <p class="text-text-primary mb-4">Pega el texto original en el primer cuadro y el texto revisado en el segundo. La herramienta resaltará las diferencias: agregados en verde, eliminados en rojo.</p>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Herramientas Relacionadas</h2>
            <ul class="space-y-2">
              <li><a href="/es/word-counter" class="text-brand-pink hover:underline">Contador de Palabras</a></li>
              <li><a href="/es/paragraph-rewriter" class="text-brand-pink hover:underline">Reescritor de Párrafos</a></li>
              <li><a href="/es/readability-checker" class="text-brand-pink hover:underline">Verificador de Legibilidad</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="text-compare" />
    </div>
  </main>

  <Footer />
</BaseLayout>
