---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
---
<BaseLayout title="Speech Word Counter - Count Words for Speeches & Presentations" description="Free speech word counter tool. Count words for speeches, presentations, and scripts. Estimate speaking time included.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Speech Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for speeches, presentations, and scripts. Estimate your speaking time based on word count.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">How to Use the Speech Word Counter</h2><p class="text-text-primary mb-4">Paste your speech or presentation script above. Get instant word count and speaking time estimates to plan your delivery.</p></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Speaking Time Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Slow pace (100 WPM)</span><span class="font-semibold">~100 words per minute</span></li><li class="flex justify-between"><span>Average pace (130 WPM)</span><span class="font-semibold">~130 words per minute</span></li><li class="flex justify-between"><span>Fast pace (160 WPM)</span><span class="font-semibold">~160 words per minute</span></li></ul><p class="text-sm text-text-muted mt-3">Average speaking pace is 130-150 words per minute. Adjust based on your delivery style and audience.</p></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Speech Length Recommendations</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li><strong>5-minute speech:</strong> 650-750 words</li><li><strong>10-minute speech:</strong> 1300-1500 words</li><li><strong>15-minute speech:</strong> 1950-2250 words</li><li><strong>20-minute speech:</strong> 2600-3000 words</li><li><strong>TED Talk (18 min):</strong> 2300-2700 words</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Speech Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Write for the ear, not the eye—use conversational language</li><li>Include pauses in your script (mark them for practice)</li><li>Practice with a timer to ensure you stay within limits</li><li>Remember: slower is better for important points</li><li>Account for audience reactions (laughter, applause)</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">FAQs</h2><h3 class="text-xl font-display font-semibold mt-4 mb-2">How many words is a 10 minute speech?</h3><p class="text-text-primary mb-4">A 10-minute speech at average pace (130-150 WPM) is approximately 1300-1500 words. Always practice with timing to be sure.</p><h3 class="text-xl font-display font-semibold mt-4 mb-2">Should I memorize my speech word-for-word?</h3><p class="text-text-primary mb-4">It's better to know your key points and speak naturally. Memorizing can make you sound robotic. Use your word count as a guide, not a script to recite.</p></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/reading-time-calculator" class="text-brand-pink hover:underline">Reading Time Calculator</a></li><li><a href="/sentence-counter" class="text-brand-pink hover:underline">Sentence Counter</a></li><li><a href="/paragraph-counter" class="text-brand-pink hover:underline">Paragraph Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <!-- Footer Ad Banner -->
  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
