---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="LinkedIn Headline Character Counter - Count Characters for LinkedIn Headlines" description="Free LinkedIn headline character counter. Count characters for LinkedIn headlines (220 chars). Optimize your LinkedIn profile for recruiters and networking.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">LinkedIn Headline Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for LinkedIn headlines. Stay within the 220 character limit and optimize for search visibility.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">LinkedIn Headline Limits 2026</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Headline</span><span class="font-semibold">220 characters</span></li><li class="flex justify-between"><span>About Section</span><span class="font-semibold">2,600 characters</span></li><li class="flex justify-between"><span>Experience Description</span><span class="font-semibold">2,000 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Headline Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Include your current role and company</li><li>Add key skills for recruiter searches</li><li>Use | or • to separate sections</li><li>Keep it professional but personable</li><li>Include value proposition, not just title</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/linkedin-post-counter" class="text-brand-pink hover:underline">LinkedIn Post Counter</a></li><li><a href="/resume-word-counter" class="text-brand-pink hover:underline">Resume Word Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
