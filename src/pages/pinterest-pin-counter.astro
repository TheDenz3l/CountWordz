---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Pinterest Pin Character Counter - Count Characters for Pinterest Titles and Descriptions" 
  description="Free Pinterest character counter. Count characters for Pinterest pin titles (100 chars) and descriptions (500 chars). Optimize your Pinterest SEO."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Pinterest Pin Character Counter</h1>
      <p class="text-base text-text-muted max-w-3xl">Count characters for Pinterest pin titles and descriptions. Optimize your pins for Pinterest SEO and maximum engagement.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CharacterCounterTool client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Pinterest Character Limits 2026</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>Pin Title</span><span class="font-semibold">100 characters</span></li>
                <li class="flex justify-between"><span>Pin Description</span><span class="font-semibold">500 characters</span></li>
                <li class="flex justify-between"><span>Board Title</span><span class="font-semibold">100 characters</span></li>
                <li class="flex justify-between"><span>Board Description</span><span class="font-semibold">500 characters</span></li>
                <li class="flex justify-between"><span>Profile Bio</span><span class="font-semibold">160 characters</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Pinterest SEO Tips</h2>
            <ul class="list-disc list-inside space-y-2 text-text-primary mb-4">
              <li>Use keywords in your pin title (first 40 chars most important)</li>
              <li>Write detailed descriptions with relevant keywords</li>
              <li>Use all 500 characters for maximum SEO benefit</li>
              <li>Include a call-to-action (save, click, visit)</li>
              <li>Add 2-5 relevant hashtags at the end</li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">FAQs</h2>
            <h3 class="text-xl font-display font-semibold mt-4 mb-2">How long should Pinterest descriptions be?</h3>
            <p class="text-text-primary mb-4">Use all 500 characters available. Longer descriptions with keywords perform better in Pinterest search results.</p>
            <h3 class="text-xl font-display font-semibold mt-4 mb-2">Do hashtags count toward the limit?</h3>
            <p class="text-text-primary mb-4">Yes, hashtags count as regular characters. Place them at the end of your description.</p>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2>
            <ul class="space-y-2">
              <li><a href="/instagram-caption-counter" class="text-brand-pink hover:underline">Instagram Caption Counter</a></li>
              <li><a href="/meta-description-counter" class="text-brand-pink hover:underline">Meta Description Counter</a></li>
              <li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="character-counter" />
    </div>
  </main>

  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
