---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadabilityCheckerTool from '../components/ReadabilityCheckerTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Young Adult Readability Checker - Check Readability for YA Content" description="Free young adult readability checker. Check readability scores for young adult books and content. Optimize for teen reader engagement.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Young Adult Readability Checker</h1><p class="text-base text-text-muted max-w-3xl">Check readability for young adult content. Optimize your writing for teen reader engagement and comprehension.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadabilityCheckerTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Young Adult Readability Standards</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Middle Grade</span><span class="font-semibold">Grade 5-7</span></li><li class="flex justify-between"><span>Young Adult</span><span class="font-semibold">Grade 7-9</span></li><li class="flex justify-between"><span>Older YA</span><span class="font-semibold">Grade 9-11</span></li><li class="flex justify-between"><span>Target Flesch Score</span><span class="font-semibold">60-75 (easy-moderate)</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">YA Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Use age-appropriate themes</li><li>Write authentic teen voices</li><li>Keep pacing engaging</li><li>Balance complexity with accessibility</li><li>Address relevant teen issues</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/childrens-book-readability-checker" class="text-brand-pink hover:underline">Children's Book Readability Checker</a></li><li><a href="/high-school-readability-checker" class="text-brand-pink hover:underline">High School Readability Checker</a></li><li><a href="/readability-checker" class="text-brand-pink hover:underline">Readability Checker</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="readability" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
