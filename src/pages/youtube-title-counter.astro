---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="YouTube Title Character Counter - Count Characters for YouTube Video Titles" description="Free YouTube title character counter. Count characters for YouTube video titles (100 chars). Optimize your YouTube SEO and click-through rates.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">YouTube Title Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for YouTube video titles. Stay within the 100 character limit and optimize for search and clicks.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">YouTube Title Limits 2026</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Video Title</span><span class="font-semibold">100 characters</span></li><li class="flex justify-between"><span>Visible in Search</span><span class="font-semibold">~60 characters</span></li><li class="flex justify-between"><span>Recommended Length</span><span class="font-semibold">50-60 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">YouTube Title Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Keep important keywords in first 60 characters</li><li>Use numbers and power words for CTR</li><li>Create curiosity without clickbait</li><li>Include year for evergreen content</li><li>Match title with thumbnail message</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/youtube-description-counter" class="text-brand-pink hover:underline">YouTube Description Counter</a></li><li><a href="/youtube-tag-counter" class="text-brand-pink hover:underline">YouTube Tag Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
