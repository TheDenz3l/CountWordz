---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingTimeTool from '../components/ReadingTimeTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Press Release Reading Time Calculator - Estimate Reading Time for Press Releases" description="Free press release reading time calculator. Estimate how long it takes to read press releases. Optimize press release length for media pickup.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Press Release Reading Time Calculator</h1><p class="text-base text-text-muted max-w-3xl">Estimate reading time for press releases. Optimize your press release length for maximum media pickup and journalist engagement.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadingTimeTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Press Release Reading Time Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Standard Press Release</span><span class="font-semibold">1.5-3 minutes</span></li><li class="flex justify-between"><span>Detailed Press Release</span><span class="font-semibold">3-5 minutes</span></li><li class="flex justify-between"><span>Media Advisory</span><span class="font-semibold">1-2 minutes</span></li><li class="flex justify-between"><span>Optimal Length</span><span class="font-semibold">2-3 minutes</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Press Release Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Lead with most newsworthy info</li><li>Follow inverted pyramid structure</li><li>Keep paragraphs short</li><li>Include quotes</li><li>End with boilerplate</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/press-release-word-counter" class="text-brand-pink hover:underline">Press Release Word Counter</a></li><li><a href="/report-reading-time" class="text-brand-pink hover:underline">Report Reading Time</a></li><li><a href="/reading-time-calculator" class="text-brand-pink hover:underline">Reading Time Calculator</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="reading-time" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
