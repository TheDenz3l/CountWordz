---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getLocalizedStaticPath, getLocalizedToolPath, getLocaleHomePath } from '../../lib/locale-routes';
import { generateFAQPageSchema } from '../../lib/seo-metadata';
import { getLongTailDirectoryEntries, readabilityDirectorySlugs, readingTimeDirectorySlugs } from '../../lib/tools-directory';
import Icon from '../../components/Icon.astro';

const locale = 'fr';
const readabilityTools = getLongTailDirectoryEntries(locale, readabilityDirectorySlugs);
const readingTimeTools = getLongTailDirectoryEntries(locale, readingTimeDirectorySlugs);

const coreTools = [
  { slug: 'word-counter', title: 'Compteur de mots', description: 'Compte mots, caractères, phrases et plus', accent: 'text-brand-pink' },
  { slug: 'character-counter', title: 'Compteur de caractères', description: 'Vérifie les limites pour les réseaux sociaux', accent: 'text-brand-cyan' },
  { slug: 'sentence-counter', title: 'Compteur de phrases', description: 'Compte les phrases et analyse leur structure', accent: 'text-brand-orange' },
  { slug: 'paragraph-counter', title: 'Compteur de paragraphes', description: 'Compte les paragraphes et la moyenne de mots', accent: 'text-brand-pink' },
  { slug: 'syllable-counter', title: 'Compteur de syllabes', description: 'Compte les syllabes dans les mots et le texte', accent: 'text-brand-cyan' },
  { slug: 'reading-time-calculator', title: 'Calculateur de temps de lecture', description: 'Estime le temps de lecture et de parole', accent: 'text-brand-orange' },
  { slug: 'case-converter', title: 'Convertisseur de casse', description: 'Convertit le texte entre différents formats', accent: 'text-brand-pink' },
  { slug: 'title-case-converter', title: 'Convertisseur de titre', description: 'Convertit le texte au bon format de titre', accent: 'text-brand-cyan' },
  { slug: 'readability-checker', title: 'Vérificateur de lisibilité', description: 'Mesure la lisibilité avec les scores clés', accent: 'text-brand-orange' },
  { slug: 'keyword-density-checker', title: 'Densité de mots-clés', description: 'Analyse la fréquence des mots et expressions', accent: 'text-brand-pink' },
  { slug: 'text-compare-tool', title: 'Comparateur de texte', description: 'Compare deux textes et surligne les différences', accent: 'text-brand-cyan' },
  { slug: 'paragraph-rewriter', title: 'Réécriture de paragraphe', description: 'Améliore la clarté et la fluidité de vos phrases', accent: 'text-brand-orange' },
];

const platformTools = [
  { slug: 'tweet-character-counter', title: 'Compteur de tweets', description: 'X / Twitter (280 caractères)' },
  { slug: 'instagram-caption-counter', title: 'Légende Instagram', description: '2 200 caractères' },
  { slug: 'linkedin-post-counter', title: 'Publication LinkedIn', description: '3 000 caractères' },
  { slug: 'tiktok-character-counter', title: 'TikTok', description: 'Bio et légendes' },
  { slug: 'facebook-post-counter', title: 'Publication Facebook', description: '63 206 caractères' },
  { slug: 'pinterest-pin-counter', title: 'Épingle Pinterest', description: 'Titre et description' },
  { slug: 'youtube-title-counter', title: 'Titre YouTube', description: '100 caractères' },
  { slug: 'youtube-tag-counter', title: 'Tags YouTube', description: '500 caractères' },
  { slug: 'email-subject-counter', title: 'Objet d’e-mail', description: '60-70 caractères' },
  { slug: 'linkedin-headline-counter', title: 'Titre LinkedIn', description: '220 caractères' },
  { slug: 'meta-title-counter', title: 'Meta titre', description: '60 caractères (SEO)' },
  { slug: 'instagram-story-counter', title: 'Story Instagram', description: '250 caractères' },
  { slug: 'tweet-thread-counter', title: 'Thread X', description: '280 par publication' },
  { slug: 'whatsapp-message-counter', title: 'Message WhatsApp', description: '4 096 caractères' },
  { slug: 'telegram-message-counter', title: 'Message Telegram', description: '4 096 caractères' },
  { slug: 'discord-message-counter', title: 'Message Discord', description: '2 000 caractères' },
  { slug: 'reddit-post-counter', title: 'Publication Reddit', description: '300 pour le titre, 40k pour le post' },
  { slug: 'sms-character-counter', title: 'SMS', description: '160 caractères' },
  { slug: 'tiktok-bio-counter', title: 'Bio TikTok', description: '80 caractères' },
];

const wordTools = [
  { slug: 'essay-word-counter', title: 'Compteur d’essais', description: 'Pour étudiants et rédacteurs' },
  { slug: 'resume-word-counter', title: 'Compteur de CV', description: 'Pour candidatures' },
  { slug: 'cover-letter-word-counter', title: 'Lettre de motivation', description: 'Pour postuler efficacement' },
  { slug: 'college-essay-word-counter', title: 'Essai universitaire', description: 'Pour admissions' },
  { slug: 'speech-word-counter', title: 'Discours', description: 'Pour interventions et présentations' },
  { slug: 'paragraph-word-counter', title: 'Compte par paragraphe', description: 'Pour sections ciblées' },
  { slug: 'article-word-counter', title: 'Article', description: 'Pour contenus éditoriaux' },
  { slug: 'thesis-word-counter', title: 'Mémoire', description: 'Pour travaux académiques' },
  { slug: 'dissertation-word-counter', title: 'Thèse', description: 'Pour travaux longs' },
  { slug: 'grant-proposal-word-counter', title: 'Proposition de subvention', description: 'Pour dossiers de financement' },
  { slug: 'book-chapter-word-counter', title: 'Chapitre de livre', description: 'Pour auteurs' },
  { slug: 'blog-post-word-counter', title: 'Article de blog', description: 'Pour blogs et newsletters' },
  { slug: 'email-word-counter', title: 'E-mail', description: 'Pour messages professionnels' },
  { slug: 'report-word-counter', title: 'Rapport', description: 'Pour documents professionnels' },
  { slug: 'whitepaper-word-counter', title: 'Livre blanc', description: 'Pour contenus experts' },
  { slug: 'script-word-counter', title: 'Script', description: 'Pour vidéo et production' },
  { slug: 'podcast-script-word-counter', title: 'Script de podcast', description: 'Pour épisodes audio' },
  { slug: 'youtube-script-word-counter', title: 'Script YouTube', description: 'Pour contenu vidéo' },
  { slug: 'presentation-word-counter', title: 'Présentation', description: 'Pour slides et prises de parole' },
  { slug: 'case-study-word-counter', title: 'Étude de cas', description: 'Pour marketing et preuve client' },
  { slug: 'press-release-word-counter', title: 'Communiqué de presse', description: 'Pour médias et RP' },
  { slug: 'product-description-word-counter', title: 'Description produit', description: 'Pour e-commerce' },
];


const faqSchema = generateFAQPageSchema({
  mainEntity: [
    { question: 'Que contient cette page d’outils ?', answer: 'Elle regroupe les principales catégories de Word Counters ainsi que des accès rapides vers les outils adaptés à différents formats de texte.' },
    { question: 'Tous les outils sont-ils gratuits ?', answer: 'Oui. Tous les outils listés ici sont gratuits et fonctionnent directement dans le navigateur.' },
    { question: 'Comment trouver le bon outil ?', answer: 'Commencez par la catégorie correspondant à votre besoin, puis ouvrez l’outil le plus adapté à votre type de contenu.' },
    { question: 'Y a-t-il aussi des outils spécialisés ?', answer: 'Oui. En plus des outils principaux, cette page relie des outils dédiés au SEO, aux réseaux sociaux, à la lisibilité et à plusieurs types de documents.' },
    { question: 'Dois-je m’inscrire ?', answer: 'Non. Aucun compte n’est nécessaire.' },
  ],
});

---

<BaseLayout 
  title="Tous les outils de texte - Liste complète des 103 outils gratuits" 
  description="Liste complète des 103 outils de texte gratuits sur Word Counters. Explorez par catégorie : compteurs de mots, compteurs de caractères, vérificateurs de lisibilité, calculateurs de temps de lecture et plus encore."
  jsonLD={[faqSchema]}
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-8">
      <h1 class="text-4xl md:text-6xl font-display font-bold tracking-tighter text-text-primary mb-3">Tous les outils de texte</h1>
      <p class="text-lg text-text-muted max-w-3xl">Parcourez les 103 outils de texte gratuits organisés par catégorie. Trouvez l’outil adapté à votre écriture, votre édition et votre optimisation de contenu.</p>
    </header>

    <section class="py-6 bg-gray-50 mb-8">
      <div class="layout-shell px-4">
        <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
          <p class="text-xs text-text-muted mb-2">Publicité</p>
          <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
            <span class="text-gray-400 text-sm">Espace publicitaire (728x90)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-pink">Outils principaux</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {coreTools.map((tool) => (
          <a href={getLocalizedStaticPath(locale, tool.slug)} class="p-4 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink hover:shadow-md transition-all">
            <h3 class={`font-semibold ${tool.accent}`}>{tool.title}</h3>
            <p class="text-sm text-text-muted mt-1">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="py-6 bg-white mb-12">
      <div class="layout-shell px-4">
        <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
          <p class="text-xs text-text-muted mb-2">Publicité</p>
          <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
            <span class="text-gray-400 text-sm">Espace publicitaire (300x250)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-cyan">Compteurs de caractères par plateforme</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {platformTools.map((tool) => (
          <a href={getLocalizedToolPath(locale, tool.slug, 'character-counter')} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-cyan transition-all">
            <h3 class="font-medium text-brand-cyan">{tool.title}</h3>
            <p class="text-xs text-text-muted mt-1">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-orange">Compteurs de mots par type de document</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {wordTools.map((tool) => (
          <a href={getLocalizedToolPath(locale, tool.slug, 'word-counter')} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-orange transition-all">
            <h3 class="font-medium text-brand-orange">{tool.title}</h3>
            <p class="text-xs text-text-muted mt-1">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-pink">Vérificateurs de Lisibilité par Industrie</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {readabilityTools.map((tool) => (
          <a href={getLocalizedToolPath(locale, tool.slug)} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-pink transition-all">
            <h3 class="font-medium text-brand-pink">{tool.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-6 pb-2 border-b-2 border-brand-cyan">Calculateurs de Temps de Lecture</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {readingTimeTools.map((tool) => (
          <a href={getLocalizedToolPath(locale, tool.slug)} class="p-3 bg-surface rounded-lg border border-gray-100 hover:border-brand-cyan transition-all">
            <h3 class="font-medium text-brand-cyan">{tool.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12 bg-surface rounded-2xl p-8 border border-gray-100">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Comment utiliser ce répertoire</h2>
      <p class="text-text-primary mb-4">Cette page sert de point d’entrée pour trouver rapidement l’outil adapté selon votre objectif : mesurer, comparer, réécrire, vérifier la lisibilité ou optimiser un texte.</p>
      <p class="text-text-primary">Plutôt que de chercher outil par outil, parcourez d’abord les catégories puis ouvrez la page la plus proche de votre format de contenu.</p>
    </section>

    <section class="mb-12 bg-surface rounded-2xl p-8 border border-gray-100">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Idéal pour</h2>
      <p class="text-text-primary">Rédacteurs, marketeurs, étudiants, équipes SEO et toute personne qui travaille régulièrement sur plusieurs formats de texte.</p>
    </section>

    <section class="mb-12 bg-surface rounded-2xl p-8 border border-gray-100">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Conseils pratiques</h2>
      <ul class="space-y-4 text-text-primary">
        <li class="flex gap-3"><span class="text-brand-pink font-bold"><Icon name="check" size={18} /></span><span>Commencez par la catégorie qui correspond à votre besoin plutôt que par le nom d’un outil.</span></li>
        <li class="flex gap-3"><span class="text-brand-cyan font-bold"><Icon name="check" size={18} /></span><span>Combinez plusieurs outils pour une révision plus complète : mots, lisibilité, caractères, temps de lecture.</span></li>
        <li class="flex gap-3"><span class="text-brand-orange font-bold"><Icon name="check" size={18} /></span><span>Gardez cette page comme index de travail si vous utilisez souvent plusieurs outils dans la même journée.</span></li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Questions Fréquentes</h2>
      <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Que trouve-t-on sur cette page ?<span class="text-brand-pink group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Vous y trouverez les outils principaux ainsi que des pages spécialisées organisées par usage et catégorie.</p></details>
      <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Tous les outils sont-ils gratuits ?<span class="text-brand-cyan group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Oui. Les outils listés ici sont accessibles gratuitement sans inscription.</p></details>
      <details class="bg-surface rounded-xl border border-gray-100 p-6 group mb-4"><summary class="font-display font-semibold cursor-pointer list-none flex justify-between items-center text-lg">Comment trouver le bon outil ?<span class="text-brand-orange group-open:rotate-180 transition-transform">▼</span></summary><p class="text-text-muted mt-4">Commencez par la catégorie correspondant à votre besoin, puis choisissez l’outil adapté au type de contenu.</p></details>
    </section>

    <section class="py-6 bg-gray-50 mb-12">
      <div class="layout-shell px-4">
        <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
          <p class="text-xs text-text-muted mb-2">Publicité</p>
          <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
            <span class="text-gray-400 text-sm">Espace publicitaire (728x90)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-brand-cream rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-display font-bold mb-4">103 outils de texte gratuits</h2>
      <p class="text-text-muted mb-6 max-w-2xl mx-auto">Tous les outils sont 100% gratuits, fonctionnent dans votre navigateur et ne nécessitent aucune inscription. Commencez immédiatement avec l’outil qui vous convient.</p>
      <a href={getLocaleHomePath(locale)} class="inline-block px-8 py-3 bg-brand-pink text-white rounded-lg font-semibold hover:bg-opacity-90 transition-all">Retour à l’accueil</a>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
