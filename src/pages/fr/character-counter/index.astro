---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CharacterCounterTool from '../../../components/CharacterCounterTool';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
import { getLocalizedToolPath } from '../../../lib/locale-routes';
---

<BaseLayout 
  title="Compteur de Caractères - Vérifie les Limites pour les Réseaux Sociaux" 
  description="Compteur de caractères gratuit. Comptez les caractères avec et sans espaces. Vérifiez les limites pour X, Instagram, LinkedIn et plus."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Compteur de Caractères</h1>
      <p class="text-base text-text-muted max-w-3xl">Comptez les caractères avec et sans espaces. Vérifiez les limites pour les publications sur les réseaux sociaux.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <CharacterCounterTool locale="fr" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicité</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espace Publicitaire</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicité</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espace Publicitaire</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Limites par Plateforme</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li class="flex justify-between"><span>X (Twitter)</span><span class="font-semibold">280 caractères</span></li>
                <li class="flex justify-between"><span>Instagram Caption</span><span class="font-semibold">2,200 caractères</span></li>
                <li class="flex justify-between"><span>LinkedIn Post</span><span class="font-semibold">3,000 caractères</span></li>
                <li class="flex justify-between"><span>Meta Description</span><span class="font-semibold">160 caractères</span></li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Comment Utiliser</h2>
            <p class="text-text-primary mb-4">Collez ou tapez votre texte ci-dessus. Le compteur affichera :</p>
            <ul class="list-disc list-inside space-y-2 text-text-primary">
              <li><strong>Caractères avec espaces</strong> — Tous les caractères</li>
              <li><strong>Caractères sans espaces</strong> — Lettres uniquement</li>
              <li><strong>Nombre de mots</strong> — Total des mots</li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Outils Connexes</h2>
            <ul class="space-y-2">
              <li><a href={getLocalizedToolPath('fr', 'tweet-character-counter', 'character-counter')} class="text-brand-pink hover:underline">Compteur de Tweets</a></li>
              <li><a href={getLocalizedToolPath('fr', 'instagram-caption-counter', 'character-counter')} class="text-brand-pink hover:underline">Instagram Caption</a></li>
              <li><a href="/fr/word-counter" class="text-brand-pink hover:underline">Compteur de Mots</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="character-counter" />
    </div>
  </main>

  <Footer />
</BaseLayout>