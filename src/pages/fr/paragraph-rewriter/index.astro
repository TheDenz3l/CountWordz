---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ParagraphRewriter from '../../../components/ParagraphRewriter';
import Sidebar from '../../../components/Sidebar.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout 
  title="Réécriveur de Paragraphes - Améliore la Clarté de votre Écriture" 
  description="Outil de réécriture de paragraphes gratuit. Obtenez des suggestions pour améliorer la clarté, la lisibilité et la structure de votre écriture."
>
  <main class="layout-shell px-4 py-6">
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Réécriveur de Paragraphes</h1>
      <p class="text-base text-text-muted max-w-3xl">Obtenez des suggestions intelligentes pour améliorer votre écriture. Corrigez la voix passive, raccourcissez les phrases longues, simplifiez les mots complexes.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
          <ParagraphRewriter locale="fr" client:load />
        </div>

        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicité</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espace Publicitaire</span>
            </div>
          </div>
        </div>

        <div class="my-6 ad-slot-mid-content">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Publicité</p>
            <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">Espace Publicitaire</span>
            </div>
          </div>
        </div>

        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Ce que Cet Outil Améliore</h2>
            <div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4">
              <ul class="space-y-2 text-text-primary">
                <li><strong>Voix passive</strong> — Suggère de passer à la voix active</li>
                <li><strong>Phrases longues</strong> — Recommande de diviser les phrases de plus de 25 mots</li>
                <li><strong>Mots complexes</strong> — Suggère des alternatives plus simples</li>
                <li><strong>Répétition</strong> — Identifie les mots trop utilisés</li>
                <li><strong>Lisibilité</strong> — Affiche les scores de lisibilité améliorés</li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Outils Connexes</h2>
            <ul class="space-y-2">
              <li><a href="/fr/word-counter" class="text-brand-pink hover:underline">Compteur de Mots</a></li>
              <li><a href="/fr/text-compare-tool" class="text-brand-pink hover:underline">Comparateur de Texte</a></li>
              <li><a href="/fr/readability-checker" class="text-brand-pink hover:underline">Vérificateur de Lisibilité</a></li>
            </ul>
          </section>
        </article>
      </div>

      <Sidebar category="paragraph-rewriter" />
    </div>
  </main>

  <Footer />
</BaseLayout>
