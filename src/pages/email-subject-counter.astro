---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Email Subject Line Character Counter - Count Characters for Email Subjects" description="Free email subject character counter. Count characters for email subject lines. Optimize for Gmail (70 chars), Outlook (60 chars), and mobile (40 chars).">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Email Subject Line Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for email subject lines. Optimize for different email clients and mobile display.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Email Subject Character Limits</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Gmail Desktop</span><span class="font-semibold">~70 characters</span></li><li class="flex justify-between"><span>Gmail Mobile</span><span class="font-semibold">~40 characters</span></li><li class="flex justify-between"><span>Outlook Desktop</span><span class="font-semibold">~60 characters</span></li><li class="flex justify-between"><span>Apple Mail</span><span class="font-semibold">~55 characters</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Subject Line Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Keep under 40 characters for mobile optimization</li><li>Put important words first</li><li>Use action verbs and urgency</li><li>Avoid spam trigger words (FREE, BUY NOW)</li><li>Personalize when possible</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/linkedin-headline-counter" class="text-brand-pink hover:underline">LinkedIn Headline Counter</a></li><li><a href="/meta-title-counter" class="text-brand-pink hover:underline">Meta Title Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
