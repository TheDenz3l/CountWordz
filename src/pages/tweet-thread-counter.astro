---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCounterTool from '../components/CharacterCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Tweet Thread Character Counter - Count Characters for Twitter Threads" description="Free tweet thread character counter. Count characters for Twitter/X threads. Plan multi-tweet threads with 280 chars per tweet.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Tweet Thread Character Counter</h1><p class="text-base text-text-muted max-w-3xl">Count characters for Twitter/X threads. Plan and optimize multi-tweet threads with 280 characters per tweet.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><CharacterCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Twitter Thread Limits 2026</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Per Tweet</span><span class="font-semibold">280 characters</span></li><li class="flex justify-between"><span>Premium Tweets</span><span class="font-semibold">25,000 characters</span></li><li class="flex justify-between"><span>Thread Length</span><span class="font-semibold">Unlimited tweets</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Thread Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Hook readers in tweet 1 (most important)</li><li>Number your tweets (1/10, 2/10, etc.)</li><li>Keep each tweet focused on one idea</li><li>Use line breaks for readability</li><li>End with a CTA or summary</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/tweet-character-counter" class="text-brand-pink hover:underline">Tweet Character Counter</a></li><li><a href="/linkedin-post-counter" class="text-brand-pink hover:underline">LinkedIn Post Counter</a></li><li><a href="/character-counter" class="text-brand-pink hover:underline">Character Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="character-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
