---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Dissertation Word Counter - Count Words for PhD Dissertations" description="Free dissertation word counter. Count words for PhD dissertations and doctoral theses. Track progress toward your dissertation word limit.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Dissertation Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for PhD dissertations. Track your progress toward doctoral dissertation word limits.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Dissertation Word Count by Chapter</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Introduction</span><span class="font-semibold">5,000-8,000 words</span></li><li class="flex justify-between"><span>Literature Review</span><span class="font-semibold">10,000-15,000 words</span></li><li class="flex justify-between"><span>Methodology</span><span class="font-semibold">8,000-12,000 words</span></li><li class="flex justify-between"><span>Results</span><span class="font-semibold">10,000-15,000 words</span></li><li class="flex justify-between"><span>Discussion</span><span class="font-semibold">15,000-20,000 words</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Dissertation Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Set word count goals for each chapter</li><li>Write consistently (500-1000 words per day)</li><li>Don't edit while writing first draft</li><li>Keep a research journal separately</li><li>Remember: references and appendices may not count</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/thesis-word-counter" class="text-brand-pink hover:underline">Thesis Word Counter</a></li><li><a href="/grant-proposal-word-counter" class="text-brand-pink hover:underline">Grant Proposal Word Counter</a></li><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
