---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadabilityCheckerTool from '../components/ReadabilityCheckerTool';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
---
<BaseLayout title="Blog Readability Checker - Check Readability Score for Blog Posts" description="Free blog readability checker. Check Flesch reading ease and grade level for your blog posts. Optimize for your audience.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Blog Readability Checker</h1><p class="text-base text-text-muted max-w-3xl">Check readability scores for blog posts. Optimize your content for your target audience's reading level.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadabilityCheckerTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Target Readability for Blogs</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>General audience blog</span><span class="font-semibold">Grade 8-10</span></li><li class="flex justify-between"><span>Technical blog</span><span class="font-semibold">Grade 10-12</span></li><li class="flex justify-between"><span>Academic blog</span><span class="font-semibold">Grade 12+</span></li><li class="flex justify-between"><span>Flesch Reading Ease</span><span class="font-semibold">60-70 (ideal)</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">How to Improve Blog Readability</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Use shorter sentences (15-20 words average)</li><li>Break up long paragraphs</li><li>Use common words instead of jargon</li><li>Add subheadings for scannability</li><li>Use bullet points and numbered lists</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li><li><a href="/sentence-counter" class="text-brand-pink hover:underline">Sentence Counter</a></li><li><a href="/blog-reading-time" class="text-brand-pink hover:underline">Blog Reading Time</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="readability" />
    </div>
  </main>
  <!-- Footer Ad Banner -->
  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
