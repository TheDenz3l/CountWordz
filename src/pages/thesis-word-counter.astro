---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Thesis Word Counter - Count Words for Thesis and Dissertations" description="Free thesis word counter. Count words for thesis, dissertations, and academic papers. Track progress toward word limits.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Thesis Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for thesis and dissertations. Track your progress toward academic word limits with real-time updates.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Thesis Word Count Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Bachelor's Thesis</span><span class="font-semibold">8,000-15,000 words</span></li><li class="flex justify-between"><span>Master's Thesis</span><span class="font-semibold">15,000-25,000 words</span></li><li class="flex justify-between"><span>PhD Dissertation</span><span class="font-semibold">60,000-100,000 words</span></li><li class="flex justify-between"><span>Abstract</span><span class="font-semibold">150-300 words</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Thesis Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Break your thesis into chapters with individual word counts</li><li>Write the introduction last (after you know your findings)</li><li>Keep track of citations separately from word count</li><li>Appendices usually don't count toward the limit</li><li>Check your institution's specific guidelines</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/dissertation-word-counter" class="text-brand-pink hover:underline">Dissertation Word Counter</a></li><li><a href="/essay-word-counter" class="text-brand-pink hover:underline">Essay Word Counter</a></li><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
