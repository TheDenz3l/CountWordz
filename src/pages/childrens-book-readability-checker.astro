---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadabilityCheckerTool from '../components/ReadabilityCheckerTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Children's Book Readability Checker - Check Readability for Children's Books" description="Free children's book readability checker. Check readability scores for children's books. Optimize for young reader comprehension levels.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Children's Book Readability Checker</h1><p class="text-base text-text-muted max-w-3xl">Check readability for children's books. Optimize your writing for young reader comprehension and enjoyment.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadabilityCheckerTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>
        <div class="my-6 ad-slot-mid-content"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Square</span></div></div></div>
        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Children's Book Readability Standards</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Picture Books</span><span class="font-semibold">Grade K-2</span></li><li class="flex justify-between"><span>Early Readers</span><span class="font-semibold">Grade 1-3</span></li><li class="flex justify-between"><span>Chapter Books</span><span class="font-semibold">Grade 3-5</span></li><li class="flex justify-between"><span>Target Flesch Score</span><span class="font-semibold">75-95 (very easy)</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Children's Book Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Use simple, concrete words</li><li>Keep sentences short</li><li>Include repetition for early readers</li><li>Match vocabulary to age group</li><li>Read aloud to test flow</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/elementary-readability-checker" class="text-brand-pink hover:underline">Elementary Readability Checker</a></li><li><a href="/young-adult-readability-checker" class="text-brand-pink hover:underline">Young Adult Readability Checker</a></li><li><a href="/readability-checker" class="text-brand-pink hover:underline">Readability Checker</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="readability" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
