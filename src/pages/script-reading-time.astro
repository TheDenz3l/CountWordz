---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingTimeTool from '../components/ReadingTimeTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Script Reading Time Calculator - Estimate Reading Time for Scripts" description="Free script reading time calculator. Estimate how long it takes to read scripts for video, film, and presentations. Plan your script length effectively.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Script Reading Time Calculator</h1><p class="text-base text-text-muted max-w-3xl">Estimate reading time for scripts. Plan your video, film, and presentation scripts for optimal pacing and audience engagement.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><ReadingTimeTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Script Reading Time Guidelines</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Short Video (1-2 min)</span><span class="font-semibold">150-300 words</span></li><li class="flex justify-between"><span>Standard Video (5 min)</span><span class="font-semibold">750 words</span></li><li class="flex justify-between"><span>Film Scene</span><span class="font-semibold">1 page = 1 minute</span></li><li class="flex justify-between"><span>Speaking Rate</span><span class="font-semibold">150 WPM</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Script Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Write for speaking, not reading</li><li>Include pause markers</li><li>Time your script by reading aloud</li><li>Keep sentences short</li><li>Match words to visuals</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/script-word-counter" class="text-brand-pink hover:underline">Script Word Counter</a></li><li><a href="/speech-time-calculator" class="text-brand-pink hover:underline">Speech Time Calculator</a></li><li><a href="/reading-time-calculator" class="text-brand-pink hover:underline">Reading Time Calculator</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="reading-time" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
