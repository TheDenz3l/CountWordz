---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { generateSoftwareApplicationSchema } from '../lib/seo-metadata';
import Icon from '../components/Icon.astro';

const softwareSchema = generateSoftwareApplicationSchema({
  name: 'Word Counter',
  description: 'Free online word counter tool. Count words, characters, sentences, paragraphs, and estimate reading time in real-time. Perfect for essays, articles, and social media posts.',
  pathname: '/word-counter',
  applicationCategory: 'SEO',
  operatingSystem: 'All',
});
---

<BaseLayout 
  title="Word Counter - Count Words, Characters, and More" 
  description="Free online word counter tool. Count words, characters, sentences, paragraphs, and estimate reading time in real-time. Perfect for essays, articles, and social media posts."
  jsonLD={[softwareSchema]}
>
  <main class="layout-shell px-4 py-6">
    <!-- Page Header -->
    <header class="mb-6">
      <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">
        Word Counter
      </h1>
      <p class="text-base text-text-muted max-w-3xl">
        Count words, characters, sentences, and more in real-time. Perfect for essays, resumes, captions, and scripts.
      </p>
    </header>

    <!-- Main Tool Area -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Tool Column -->
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <WordCounterTool locale="en" client:load />
        </div>

        <!-- Below-Tool Ad Slot -->
        <div class="mt-4 ad-slot-below-tool">
          <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
            <p class="text-xs text-text-muted mb-2">Advertisement</p>
            <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
              <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
            </div>
          </div>
        </div>

        <!-- SEO Content -->
        <article class="mt-8">
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">How to Use the Word Counter</h2>
            <p class="text-text-primary mb-4">
              Simply paste or type your text into the box above. The word counter will instantly analyze your text and display accurate counts for:
            </p>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-4">
              <div class="bg-surface p-3 rounded-lg border border-gray-100">
                <div class="text-brand-pink font-semibold">Word Count</div>
                <div class="text-xs text-text-muted">Total words</div>
              </div>
              <div class="bg-surface p-3 rounded-lg border border-gray-100">
                <div class="text-brand-cyan font-semibold">Characters</div>
                <div class="text-xs text-text-muted">With/without spaces</div>
              </div>
              <div class="bg-surface p-3 rounded-lg border border-gray-100">
                <div class="text-brand-orange font-semibold">Sentences</div>
                <div class="text-xs text-text-muted">Sentence count</div>
              </div>
              <div class="bg-surface p-3 rounded-lg border border-gray-100">
                <div class="text-brand-pink font-semibold">Paragraphs</div>
                <div class="text-xs text-text-muted">Paragraph count</div>
              </div>
              <div class="bg-surface p-3 rounded-lg border border-gray-100">
                <div class="text-brand-cyan font-semibold">Reading Time</div>
                <div class="text-xs text-text-muted">Minutes to read</div>
              </div>
              <div class="bg-surface p-3 rounded-lg border border-gray-100">
                <div class="text-brand-orange font-semibold">Speaking Time</div>
                <div class="text-xs text-text-muted">Minutes to speak</div>
              </div>
            </div>
          </section>

          <!-- Specific Use Cases -->
          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Specific Use Cases</h2>
            <p class="text-text-primary mb-4">Need a word counter for a specific purpose? Try our specialized tools:</p>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              <a href="/essay-word-counter" class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
                <div class="text-brand-pink font-semibold text-sm">Essay Word Counter</div>
                <div class="text-xs text-text-muted mt-1">For assignments</div>
              </a>
              <a href="/resume-word-counter" class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
                <div class="text-brand-cyan font-semibold text-sm">Resume Counter</div>
                <div class="text-xs text-text-muted mt-1">For job applications</div>
              </a>
              <a href="/cover-letter-word-counter" class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
                <div class="text-brand-orange font-semibold text-sm">Cover Letter</div>
                <div class="text-xs text-text-muted mt-1">For applications</div>
              </a>
              <a href="/college-essay-word-counter" class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
                <div class="text-brand-pink font-semibold text-sm">College Essay</div>
                <div class="text-xs text-text-muted mt-1">For admissions</div>
              </a>
              <a href="/speech-word-counter" class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
                <div class="text-brand-cyan font-semibold text-sm">Speech Counter</div>
                <div class="text-xs text-text-muted mt-1">For presentations</div>
              </a>
              <a href="/paragraph-word-counter" class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
                <div class="text-brand-orange font-semibold text-sm">Paragraph Count</div>
                <div class="text-xs text-text-muted mt-1">By paragraph</div>
              </a>
            </div>
          </section>

          <!-- Mid-Content Ad Slot -->
          <div class="my-6 ad-slot-mid-content">
            <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
              <p class="text-xs text-text-muted mb-2">Advertisement</p>
              <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
                <span class="text-gray-400 text-sm">AdSense Square (300x250)</span>
              </div>
            </div>
          </div>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Best For</h2>
            <p class="text-text-primary mb-4">
              The Word Counter is ideal for anyone who needs precise text metrics for writing, editing, or content optimization. It's particularly valuable for time-sensitive tasks where quick, accurate counts matter.
            </p>
            <div class="bg-brand-cream rounded-xl p-5 mb-4">
              <h3 class="text-lg font-display font-semibold mb-3">Perfect For:</h3>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 text-text-primary">
                <li class="flex items-center gap-2">
                  <span class="text-brand-pink"><Icon name="check" size={18} /></span>
                  <span>Students checking essay word limits</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-brand-pink"><Icon name="check" size={18} /></span>
                  <span>Writers tracking daily word count</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-brand-pink"><Icon name="check" size={18} /></span>
                  <span>Marketers optimizing ad copy</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-brand-pink"><Icon name="check" size={18} /></span>
                  <span>Job seekers crafting resumes</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-brand-pink"><Icon name="check" size={18} /></span>
                  <span>Social media creators</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-brand-pink"><Icon name="check" size={18} /></span>
                  <span>Bloggers and content writers</span>
                </li>
              </ul>
            </div>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-3">Practical Tips</h2>
            <ul class="list-disc list-inside space-y-2 text-text-primary mb-4">
              <li>Use the reading time estimate to plan content length for your audience</li>
              <li>Check character counts alongside word counts for social media posts</li>
              <li>Break long documents into sections to track progress toward word goals</li>
              <li>Use the sentence and paragraph counts to improve content structure</li>
              <li>Compare speaking time vs reading time when preparing presentations</li>
            </ul>
          </section>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Frequently Asked Questions</h2>
            
            <div class="mb-4">
              <h3 class="text-lg font-display font-semibold mb-2">How do you count words?</h3>
              <p class="text-text-primary">
                We count words by splitting your text on whitespace and filtering out empty strings. This handles multiple spaces, tabs, and newlines correctly. Our algorithm is designed to match the word counting logic used by popular word processors like Microsoft Word and Google Docs.
              </p>
            </div>

            <div class="mb-4">
              <h3 class="text-lg font-display font-semibold mb-2">What counts as a word?</h3>
              <p class="text-text-primary">
                Any sequence of characters separated by spaces counts as one word. Hyphenated words like "well-known" count as one word. Contractions like "don't" count as one word. Numbers and symbols separated by spaces also count as words.
              </p>
            </div>

            <!-- Inline Ad Slot -->
            <div class="my-6 ad-slot-inline">
              <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
                <p class="text-xs text-text-muted mb-2">Advertisement</p>
                <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
                  <span class="text-gray-400 text-sm">AdSense Banner</span>
                </div>
              </div>
            </div>

            <div class="mb-4">
              <h3 class="text-lg font-display font-semibold mb-2">How accurate is the reading time?</h3>
              <p class="text-text-primary">
                Reading time is calculated based on an average reading speed of 200 words per minute. This is the standard reading speed used by most readability tools. Actual reading time may vary based on text complexity, formatting, and individual reading speed. Technical or academic content may take longer to read.
              </p>
            </div>

            <div class="mb-4">
              <h3 class="text-lg font-display font-semibold mb-2">Is my text saved or stored?</h3>
              <p class="text-text-primary">
                No. All text analysis happens entirely in your browser using JavaScript. Your text is never sent to our servers or stored anywhere. This means your data remains private and secure, and the tool works even without an internet connection.
              </p>
            </div>

            <div class="mb-4">
              <h3 class="text-lg font-display font-semibold mb-2">Can I use this for social media posts?</h3>
              <p class="text-text-primary">
                Absolutely! Our word counter is perfect for checking social media post lengths. Twitter/X allows 280 characters, Instagram captions allow 2,200 characters, and LinkedIn posts allow 3,000 characters. Use our character counter alongside this tool to stay within platform limits.
              </p>
            </div>

            <div class="mb-4">
              <h3 class="text-lg font-display font-semibold mb-2">Does this work offline?</h3>
              <p class="text-text-primary">
                Yes! Once the page loads, the word counter works entirely in your browser without needing an internet connection. All text analysis happens locally using JavaScript, so you can use it anywhere.
              </p>
            </div>
          </section>

          <!-- Bottom Ad Slot Before Related Tools -->
          <div class="my-6 ad-slot-bottom">
            <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
              <p class="text-xs text-text-muted mb-2">Advertisement</p>
              <div class="min-h-[250px] flex items-center justify-center bg-gray-50 rounded">
                <span class="text-gray-400 text-sm">AdSense Square</span>
              </div>
            </div>
          </div>

          <section class="mb-6">
            <h2 class="text-2xl font-display font-bold mb-4">Related Tools</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <a href="/character-counter" class="bg-surface p-4 rounded-lg border border-gray-200 hover:border-brand-pink transition-colors">
                <div class="font-semibold text-text-primary">Character Counter</div>
                <div class="text-sm text-text-muted">Check character limits for social media</div>
              </a>
              <a href="/sentence-counter" class="bg-surface p-4 rounded-lg border border-gray-200 hover:border-brand-pink transition-colors">
                <div class="font-semibold text-text-primary">Sentence Counter</div>
                <div class="text-sm text-text-muted">Analyze sentence structure</div>
              </a>
              <a href="/readability-checker" class="bg-surface p-4 rounded-lg border border-gray-200 hover:border-brand-pink transition-colors">
                <div class="font-semibold text-text-primary">Readability Checker</div>
                <div class="text-sm text-text-muted">Measure text complexity</div>
              </a>
              <a href="/paragraph-counter" class="bg-surface p-4 rounded-lg border border-gray-200 hover:border-brand-pink transition-colors">
                <div class="font-semibold text-text-primary">Paragraph Counter</div>
                <div class="text-sm text-text-muted">Count and analyze paragraphs</div>
              </a>
            </div>
          </section>
        </article>
      </div>

      <Sidebar />
    </div>
  </main>

    <!-- Footer Ad Banner -->
  <section class="py-6 bg-white">
    <div class="layout-shell px-4">
      <div class="bg-surface rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-text-muted mb-2">Advertisement</p>
        <div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded">
          <span class="text-gray-400 text-sm">AdSense Banner (728x90)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
