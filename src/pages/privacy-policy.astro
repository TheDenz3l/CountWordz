---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const page = {
  title: 'Privacy Policy',
  description: 'Learn how CountWordz handles text, analytics, advertising, and privacy across the site.',
  h1: 'Privacy Policy',
  updated: 'Last updated: April 2, 2026',
  intro: 'CountWordz is designed to work in the browser without requiring an account. This page explains what data we collect, what we do not collect, and how we handle analytics and advertising.',
  sections: [
    {
      heading: 'Text you enter',
      body: 'Text entered into the tools is processed entirely in your browser for counting, readability, comparison, and formatting features. Your text is never sent to our servers or any third party. We do not require you to create an account to use the tools.',
    },
    {
      heading: 'Analytics',
      body: 'We may use privacy-conscious analytics and search performance tools to understand site usage, popular pages, and product quality. Those tools may collect aggregate usage information such as page views, referrers, and device/browser metadata.',
    },
    {
      heading: 'Advertising and cookies',
      body: 'This site displays advertisements served by Google AdSense and potentially other third-party advertising networks. These third-party vendors, including Google, use cookies, web beacons, and similar technologies to serve ads based on your prior visits to this website or other websites. Google\'s use of advertising cookies enables it and its partners to serve ads to you based on your visit to this site and/or other sites on the Internet. You may opt out of personalized advertising by visiting Google Ads Settings (https://www.google.com/settings/ads). For more information about how Google uses data when you use our site, visit: https://policies.google.com/technologies/partner-sites',
    },
    {
      heading: 'Cookies and similar technologies',
      body: 'Cookies are small text files stored on your device by your web browser. We and our third-party partners use cookies and similar technologies (such as web beacons, pixel tags, and IP addresses) for analytics, advertising, and site performance. Third-party ad servers or ad networks may use these technologies to measure the effectiveness of their advertisements and to personalize the advertising content you see. CountWordz has no access to or control over cookies that are used by third-party advertisers. You can manage your cookie preferences through your browser settings or through the cookie consent controls provided on this site.',
    },
    {
      heading: 'Third-party services',
      body: 'We use third-party services including Google AdSense for advertising and Google Fonts for typography. These services may collect information sent by your browser as part of a web page request, such as your IP address, browser type, browser language, the date and time of your request, and one or more cookies that may uniquely identify your browser. Each third-party service is governed by its own privacy policy.',
    },
    {
      heading: 'Children\'s privacy',
      body: 'CountWordz is not directed at children under the age of 13. We do not knowingly collect personal information from children under 13. If you believe we have inadvertently collected information from a child under 13, please contact us so we can take appropriate action.',
    },
    {
      heading: 'Your choices',
      body: 'You can stop using the site at any time. You can manage cookies through the cookie consent banner on this site, through your browser settings, or by using browser privacy controls and content blockers. You may opt out of personalized advertising by visiting Google Ads Settings at https://www.google.com/settings/ads or the Network Advertising Initiative opt-out page at https://www.networkadvertising.org/managing/opt_out.asp',
    },
    {
      heading: 'Changes to this policy',
      body: 'We may update this privacy policy from time to time to reflect changes in our practices or applicable laws. We encourage you to review this page periodically for the latest information on our privacy practices.',
    },
    {
      heading: 'Contact',
      body: 'If you have a privacy question about CountWordz, contact the site operator through the appropriate support or contact channel associated with the site.',
    },
  ],
};
---

<BaseLayout title={`${page.title} — CountWordz`} description={page.description}>
  <main class="layout-shell px-4 py-10">
    <div class="max-w-4xl mx-auto">
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-3">{page.h1}</h1>
        <p class="text-sm text-text-muted">{page.updated}</p>
      </header>

      <article class="bg-surface rounded-2xl border border-gray-100 p-6 md:p-8 space-y-8">
        <p class="text-text-primary leading-7">{page.intro}</p>

        {page.sections.map((section) => (
          <section>
            <h2 class="text-2xl font-display font-bold mb-3">{section.heading}</h2>
            <p class="text-text-primary leading-7">{section.body}</p>
          </section>
        ))}
      </article>
    </div>
  </main>

  <Footer locale="en" />
</BaseLayout>
