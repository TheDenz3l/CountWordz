---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCounterTool from '../components/WordCounterTool';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Book Chapter Word Counter - Count Words for Book Chapters" description="Free book chapter word counter. Count words for book chapters. Track progress toward chapter and book word limits.">
  <main class="layout-shell px-4 py-6">
    <header class="mb-6"><h1 class="text-3xl md:text-5xl font-display font-bold tracking-tighter text-text-primary mb-2">Book Chapter Word Counter</h1><p class="text-base text-text-muted max-w-3xl">Count words for book chapters. Track your progress toward chapter and manuscript word goals.</p></header>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3">
        <div class="bg-surface rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4"><WordCounterTool client:load /></div>
        <div class="mt-4 ad-slot-below-tool"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div>        <article class="mt-8">
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Book Chapter Word Counts by Genre</h2><div class="bg-surface rounded-lg border border-gray-100 p-4 mb-4"><ul class="space-y-2 text-text-primary"><li class="flex justify-between"><span>Fiction Chapter</span><span class="font-semibold">2,500-5,000 words</span></li><li class="flex justify-between"><span>Non-Fiction Chapter</span><span class="font-semibold">3,000-6,000 words</span></li><li class="flex justify-between"><span>Academic Chapter</span><span class="font-semibold">5,000-10,000 words</span></li><li class="flex justify-between"><span>Novel Total</span><span class="font-semibold">60,000-100,000 words</span></li></ul></div></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Chapter Writing Tips</h2><ul class="list-disc list-inside space-y-2 text-text-primary mb-4"><li>Set word count goals per chapter</li><li>End chapters with hooks or cliffhangers</li><li>Vary chapter length for pacing</li><li>Track subplots across chapters</li><li>Revise chapter transitions carefully</li></ul></section>
          <section class="mb-6"><h2 class="text-2xl font-display font-bold mb-3">Related Tools</h2><ul class="space-y-2"><li><a href="/blog-post-word-counter" class="text-brand-pink hover:underline">Blog Post Word Counter</a></li><li><a href="/article-word-counter" class="text-brand-pink hover:underline">Article Word Counter</a></li><li><a href="/word-counter" class="text-brand-pink hover:underline">Word Counter</a></li></ul></section>
        </article>
      </div>
      <Sidebar category="word-counter" />
    </div>
  </main>
  <section class="py-6 bg-white"><div class="layout-shell px-4"><div class="bg-surface rounded-lg border border-gray-200 p-4 text-center"><p class="text-xs text-text-muted mb-2">Advertisement</p><div class="min-h-[90px] flex items-center justify-center bg-gray-50 rounded"><span class="text-gray-400 text-sm">AdSense Banner</span></div></div></div></section>
  <Footer />
</BaseLayout>
