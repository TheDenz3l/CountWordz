---
// Footer Component - Reusable across all pages
---

<footer class="bg-gray-900 text-white py-12 mt-16">
  <div class="layout-shell px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <h3 class="text-xl font-display font-bold mb-4">CountWordz</h3>
        <p class="text-gray-400 text-sm">Free text utility tools for counting, analyzing, and formatting text. Fast, modern, and easy to use.</p>
      </div>
      
      <!-- All Tools -->
      <div class="md:col-span-2">
        <h4 class="font-semibold mb-4">Core Tools</h4>
        <div class="grid grid-cols-2 gap-2 text-sm mb-4">
          <div>
            <a href="/word-counter" class="block text-gray-400 hover:text-white py-1">Word Counter</a>
            <a href="/character-counter" class="block text-gray-400 hover:text-white py-1">Character Counter</a>
            <a href="/sentence-counter" class="block text-gray-400 hover:text-white py-1">Sentence Counter</a>
            <a href="/paragraph-counter" class="block text-gray-400 hover:text-white py-1">Paragraph Counter</a>
            <a href="/syllable-counter" class="block text-gray-400 hover:text-white py-1">Syllable Counter</a>
            <a href="/reading-time-calculator" class="block text-gray-400 hover:text-white py-1">Reading Time</a>
          </div>
          <div>
            <a href="/case-converter" class="block text-gray-400 hover:text-white py-1">Case Converter</a>
            <a href="/title-case-converter" class="block text-gray-400 hover:text-white py-1">Title Case</a>
            <a href="/readability-checker" class="block text-gray-400 hover:text-white py-1">Readability Checker</a>
            <a href="/keyword-density-checker" class="block text-gray-400 hover:text-white py-1">Keyword Density</a>
            <a href="/text-compare-tool" class="block text-gray-400 hover:text-white py-1">Text Compare</a>
            <a href="/paragraph-rewriter" class="block text-gray-400 hover:text-white py-1">Paragraph Rewriter</a>
          </div>
        </div>
        <a href="/tools" class="inline-block px-4 py-2 bg-brand-pink text-white rounded-lg text-sm font-semibold hover:bg-opacity-90 transition-all">View All 103 Tools →</a>
      </div>
      
      <!-- Legal -->
      <div>
        <h4 class="font-semibold mb-4">Legal</h4>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="/privacy-policy" class="hover:text-white">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-white">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-800 pt-8 text-center text-gray-400 text-sm">
      <p>&copy; {new Date().getFullYear()} CountWordz. All rights reserved.</p>
    </div>
  </div>
</footer>
